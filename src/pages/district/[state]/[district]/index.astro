---
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import DistrictMapStatic from '../../../../components/DistrictMapStatic.astro';
import { formatCurrency, formatPopulation, getStates } from '../../../../lib/data-loader';

export function getStaticPaths() {
  const states = getStates();
  return states.flatMap(s =>
    s.districts.map(d => ({
      params: { state: s.slug, district: d.id },
      props: { district: d, stateName: s.name, stateSlug: s.slug }
    }))
  );
}

const { district: d, stateName, stateSlug } = Astro.props;
const eco = d.economy || {} as any;
const demo = d.demographics || {} as any;
const roadmap = (d as any).roadmap;
const industries = (d as any).industries;
const liveData = (d as any).liveData;
const kdem = (d as any).kdem;
const communityInsights = (d as any).communityInsights;
const dataSources = (d as any).dataSources || [];
const portalUrl = `/district/${stateSlug}/${d.id}/portal`;
const discussUrl = `${portalUrl}?tab=discuss`;

// Phase 1 progress
const phase1 = roadmap?.phases?.phase1;
const phase1Progress = phase1?.progress || 0;

// Sector count + jobs
const sectorCount = industries?.sectors?.length || 0;
const totalJobs = roadmap?.jobsToCreate || industries?.overview?.totalJobs || 0;

// Next steps count
const nextStepCount = phase1?.components?.filter((c: any) => c.progress > 0 && c.progress < 100).length || 0;
---

<BaseLayout title={d.name} description={`Development briefing for ${d.name} district, ${stateName}`}>
  <nav class="breadcrumb">
    <a href="/">India</a>
    <span class="sep">&rsaquo;</span>
    <a href={`/state/${stateSlug}`}>{stateName}</a>
    <span class="sep">&rsaquo;</span>
    <strong style="color:var(--gray-800);">{d.name}</strong>
  </nav>

  <!-- Hero -->
  <header class="district-hero animate-up">
    <DistrictMapStatic districtName={d.name} stateName={stateName} size={64} />
    <div>
      <h1 class="district-name">{d.name}</h1>
      <p class="district-meta">{stateName} &middot; {d.lastUpdated || 'March 2026'}</p>
    </div>
  </header>

  <!-- Headline KPIs -->
  <div class="headline animate-up delay-1">
    {eco.perCapitaIncome && <span class="hl"><strong>{formatCurrency(eco.perCapitaIncome)}</strong> PCI</span>}
    {eco.gddp_crores && <span class="hl"><strong>₹{eco.gddp_crores.toLocaleString('en-IN')} Cr</strong> GDDP</span>}
    {demo.population && <span class="hl"><strong>{formatPopulation(demo.population)}</strong> population</span>}
    {d.rankings?.perCapitaIncome?.stateRank && <span class="hl rank"><strong>{d.rankings.perCapitaIncome.stateRank}</strong> in {stateName}</span>}
  </div>

  <!-- Cards Grid -->
  <div class="cards-grid">

    {/* ① Today */}
    <a href={`${portalUrl}#today`} class="card animate-up delay-1">
      <div class="card-icon">📊</div>
      <div class="card-body">
        <div class="card-title">{d.name} Today</div>
        <div class="card-stats">
          {demo.area_sq_km && <span>{demo.area_sq_km.toLocaleString('en-IN')} km²</span>}
          {demo.literacyRate && <span>{demo.literacyRate}% literacy</span>}
          {eco.gddpComposition && <span>{eco.gddpComposition.services}% services · {eco.gddpComposition.agriculture}% agri · {eco.gddpComposition.industry}% industry</span>}
        </div>
        {demo.population && <div class="card-teaser">{((demo.rural/demo.population)*100).toFixed(0)}% rural · Sex ratio {demo.sexRatio} · Density {demo.density}/km²</div>}
        {liveData?.commodityPrices && (
          <div class="card-live">
            <span class="live-dot"></span>
            {Object.entries(liveData.commodityPrices).slice(0, 2).map(([k, v]: [string, any]) => (
              <span class="card-live-item">{k.replace(/([A-Z])/g, ' $1').trim()} ₹{v.price?.toLocaleString('en-IN')}/q <span class={v.percentChange >= 0 ? 'up' : 'down'}>{v.percentChange >= 0 ? '+' : ''}{v.percentChange}%</span></span>
            ))}
          </div>
        )}
      </div>
      <span class="card-arrow">→</span>
    </a>

    {/* ② Strengths & Challenges */}
    {(d.strengths?.length || d.challenges?.length) && (
      <a href={`${portalUrl}#strengths`} class="card animate-up delay-2">
        <div class="card-icon">⚖️</div>
        <div class="card-body">
          <div class="card-title">Strengths & Challenges</div>
          <div class="card-kpi-row">
            {d.strengths?.length > 0 && <span class="card-kpi green">✓ {d.strengths.length}</span>}
            {d.challenges?.length > 0 && <span class="card-kpi red">✗ {d.challenges.length}</span>}
          </div>
          <ul class="card-teaser-list">
            {d.strengths?.slice(0, 2).map(s => <li class="teaser-strength">✓ {s.length > 60 ? s.slice(0, 57) + '...' : s}</li>)}
            {d.challenges?.slice(0, 1).map(c => <li class="teaser-challenge">✗ {c.length > 60 ? c.slice(0, 57) + '...' : c}</li>)}
          </ul>
          {communityInsights?.count > 0 && (
            <div class="card-badge">{communityInsights.count} community insights added</div>
          )}
        </div>
        <span class="card-arrow">→</span>
      </a>
    )}

    {/* ③ Opportunities */}
    {(sectorCount > 0 || d.opportunities?.length) && (
      <a href={`${portalUrl}#opportunities`} class="card animate-up delay-3">
        <div class="card-icon">⚡</div>
        <div class="card-body">
          <div class="card-title">Opportunities</div>
          <div class="card-kpi-row">
            {sectorCount > 0 && <span class="card-kpi">{sectorCount} sectors</span>}
            {totalJobs > 0 && <span class="card-kpi">{totalJobs.toLocaleString('en-IN')} jobs</span>}
            {industries?.overview?.totalInvestment && <span class="card-kpi">₹{industries.overview.totalInvestment.toLocaleString('en-IN')} Cr</span>}
          </div>
          {industries?.sectors?.length > 0 && (
            <div class="card-teaser">{industries.sectors.map((s: any) => s.name).join(' · ')}</div>
          )}
          {d.opportunities?.length > 0 && (
            <ul class="card-teaser-list">
              {d.opportunities.slice(0, 2).map(o => <li>⚡ {o.length > 55 ? o.slice(0, 52) + '...' : o}</li>)}
            </ul>
          )}
        </div>
        <span class="card-arrow">→</span>
      </a>
    )}

    {/* ④ Goals */}
    {roadmap && (
      <a href={`${portalUrl}#goals`} class="card animate-up delay-4">
        <div class="card-icon">🎯</div>
        <div class="card-body">
          <div class="card-title">Goals</div>
          <div class="card-goals">
            {roadmap.perCapitaGoal && eco.perCapitaIncome && (
              <div class="card-goal-pair">
                <span class="goal-now">{formatCurrency(eco.perCapitaIncome)}</span>
                <span class="goal-sep">→</span>
                <span class="goal-future">{formatCurrency(roadmap.perCapitaGoal)}</span>
                <span class="goal-what">PCI</span>
              </div>
            )}
            {roadmap.targetRank && d.rankings?.perCapitaIncome?.stateRank && (
              <div class="card-goal-pair">
                <span class="goal-now">{d.rankings.perCapitaIncome.stateRank}</span>
                <span class="goal-sep">→</span>
                <span class="goal-future">{roadmap.targetRank}</span>
                <span class="goal-what">Rank</span>
              </div>
            )}
          </div>
          {roadmap.jobsToCreate && <div class="card-teaser">{roadmap.jobsToCreate.toLocaleString('en-IN')} jobs · ₹{roadmap.totalInvestment?.toLocaleString('en-IN')} Cr investment</div>}
        </div>
        <span class="card-arrow">→</span>
      </a>
    )}

    {/* ⑤ Strategic Roadmap */}
    {roadmap && (
      <a href={`${portalUrl}?tab=data#roadmap`} class="card animate-up delay-5">
        <div class="card-icon">🗺️</div>
        <div class="card-body">
          <div class="card-title">Strategic Roadmap</div>
          <div class="card-kpi-row">
            <span class="card-kpi">{Object.keys(roadmap.phases).length} phases</span>
            <span class="card-kpi">{phase1Progress}% Phase 1</span>
          </div>
          <div class="card-phase-bar"><div class="card-phase-fill" style={`width:${phase1Progress}%`}></div></div>
          {phase1?.components && (
            <div class="card-teaser">{phase1.components.slice(0, 3).map((c: any) => c.name).join(' · ')}</div>
          )}
          <div class="card-sub">{phase1?.name} · {phase1?.years} · ₹{phase1?.budget?.toLocaleString('en-IN')} Cr</div>
        </div>
        <span class="card-arrow">→</span>
      </a>
    )}

    {/* ⑥ Next Steps */}
    {nextStepCount > 0 && (
      <a href={`${portalUrl}#nextsteps`} class="card animate-up delay-6">
        <div class="card-icon">📋</div>
        <div class="card-body">
          <div class="card-title">Next Steps</div>
          <div class="card-kpi-row">
            <span class="card-kpi">{nextStepCount} in progress</span>
          </div>
          <ul class="card-teaser-list">
            {phase1?.components?.filter((c: any) => c.progress > 0 && c.progress < 100).slice(0, 3).map((c: any) => (
              <li>{c.name} — {c.progress}%</li>
            ))}
          </ul>
        </div>
        <span class="card-arrow">→</span>
      </a>
    )}

    {/* ⑦ Data Sources */}
    {dataSources.length > 0 && (
      <a href={`${portalUrl}#sources`} class="card animate-up">
        <div class="card-icon">📚</div>
        <div class="card-body">
          <div class="card-title">Data Sources</div>
          <div class="card-kpi-row">
            <span class="card-kpi">{dataSources.length} sources</span>
            {d.dataCompleteness?.lastVerified && <span class="card-kpi">Verified {d.dataCompleteness.lastVerified}</span>}
          </div>
          <div class="card-teaser">{dataSources.slice(0, 4).map((s: any) => s.name).join(' · ')}</div>
        </div>
        <span class="card-arrow">→</span>
      </a>
    )}

    {/* ⑧ Community */}
    <a href={discussUrl} class="card card-community animate-up">
      <div class="card-icon">💬</div>
      <div class="card-body">
        <div class="card-title">Community</div>
        {communityInsights?.count > 0 ? (
          <Fragment>
            <div class="card-kpi-row">
              <span class="card-kpi green">{communityInsights.count} insights added to data</span>
            </div>
            {communityInsights.contributors?.length > 0 && (
              <div class="card-teaser">Contributors: {communityInsights.contributors.join(', ')}</div>
            )}
          </Fragment>
        ) : (
          <div class="card-teaser">Be the first to share what you know about {d.name}</div>
        )}
        {communityInsights?.unverified?.length > 0 && (
          <div class="card-sub">{communityInsights.unverified.length} insights awaiting verification</div>
        )}
      </div>
      <span class="card-arrow">→</span>
    </a>

  </div>

  {/* KDEM strip — only for districts with digital economy data */}
  {kdem && (
    <div class="kdem-bar animate-up">
      <span class="kdem-label">💻 {kdem.clusterName}</span>
      <span class="kdem-stats">
        {kdem.targets2030?.startups && <span>{kdem.targets2030.startups} startups</span>}
        {kdem.targets2030?.jobs && <span>{kdem.targets2030.jobs.toLocaleString('en-IN')} jobs</span>}
        <span>by 2030</span>
      </span>
      <a href={`${portalUrl}#kdem`} class="kdem-link">View →</a>
    </div>
  )}
</BaseLayout>

<style>
  .district-hero { display: flex; align-items: center; gap: 1rem; margin-bottom: 0.75rem; }
  .district-name {
    font-family: var(--font-display); font-size: 2rem; font-weight: 700;
    color: var(--gray-900); letter-spacing: -0.02em; line-height: 1.1;
  }
  .district-meta { font-size: 0.8125rem; color: var(--gray-400); margin-top: 0.125rem; }

  /* Headline KPIs */
  .headline {
    display: flex; flex-wrap: wrap; gap: 0.375rem 1.25rem; margin-bottom: 1.5rem;
    padding-bottom: 1rem; border-bottom: 1px solid var(--gray-200);
  }
  .hl { font-size: 0.875rem; color: var(--gray-500); }
  .hl strong { color: var(--gray-900); font-weight: 800; }
  .hl.rank strong { color: var(--red); }

  /* Cards Grid */
  .cards-grid {
    display: grid; grid-template-columns: repeat(4, 1fr);
    gap: 0.875rem; margin-bottom: 1.5rem;
  }

  .card {
    display: flex; align-items: flex-start; gap: 0.75rem;
    background: white; border: 1px solid var(--gray-200); border-radius: var(--radius-lg);
    padding: 1.125rem; text-decoration: none; color: inherit;
    transition: all 0.2s; position: relative;
  }
  .card:hover { border-color: var(--primary); box-shadow: var(--shadow-md); transform: translateY(-2px); }
  .card-icon { font-size: 1.25rem; flex-shrink: 0; margin-top: 0.125rem; }
  .card-body { flex: 1; min-width: 0; }
  .card-title { font-size: 0.8125rem; font-weight: 700; color: var(--gray-800); margin-bottom: 0.375rem; }
  .card-kpi-row { display: flex; gap: 0.5rem; flex-wrap: wrap; margin-bottom: 0.25rem; }
  .card-kpi {
    font-size: 0.75rem; font-weight: 800; color: var(--gray-900);
    background: var(--gray-100); padding: 0.125rem 0.375rem; border-radius: 3px;
  }
  .card-kpi.green { color: var(--green-dark); background: var(--green-light); }
  .card-kpi.red { color: var(--red-dark); background: var(--red-light); }
  .card-sub { font-size: 0.6875rem; color: var(--gray-400); line-height: 1.4; }
  .card-teaser { font-size: 0.6875rem; color: var(--gray-500); line-height: 1.4; margin-bottom: 0.25rem; }
  .card-teaser-list { list-style: none; margin: 0.25rem 0; }
  .card-teaser-list li { font-size: 0.6875rem; color: var(--gray-600); line-height: 1.5; }
  .teaser-strength { color: var(--green-dark); }
  .teaser-challenge { color: var(--red-dark); }

  /* Goals mini */
  .card-goals { display: flex; flex-direction: column; gap: 0.25rem; margin-bottom: 0.25rem; }
  .card-goal-pair { display: flex; align-items: center; gap: 0.25rem; font-size: 0.75rem; }
  .goal-now { color: var(--gray-400); font-weight: 700; }
  .goal-sep { color: var(--gray-300); }
  .goal-future { color: var(--primary); font-weight: 800; }
  .goal-what { color: var(--gray-400); font-size: 0.5625rem; text-transform: uppercase; letter-spacing: 0.04em; }

  /* Phase bar mini */
  .card-phase-bar { height: 4px; background: var(--gray-100); border-radius: 2px; overflow: hidden; margin: 0.375rem 0; }
  .card-phase-fill { height: 100%; border-radius: 2px; background: linear-gradient(90deg, var(--primary), var(--teal)); }
  .card-badge {
    font-size: 0.5625rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.04em;
    color: var(--green-dark); background: var(--green-light);
    padding: 0.125rem 0.375rem; border-radius: 3px; display: inline-block; margin-top: 0.25rem;
  }
  .card-arrow {
    font-size: 1rem; color: var(--gray-300); flex-shrink: 0;
    transition: color 0.2s; margin-top: 0.125rem;
  }
  .card:hover .card-arrow { color: var(--primary); }

  /* Live data in card */
  .card-live { display: flex; align-items: center; gap: 0.5rem; margin-top: 0.375rem; }
  .live-dot { width: 5px; height: 5px; border-radius: 50%; background: var(--green); flex-shrink: 0; }
  .card-live-item { font-size: 0.625rem; color: var(--gray-500); }
  .card-live-item .up { color: var(--green); font-weight: 700; }
  .card-live-item .down { color: var(--red); font-weight: 700; }
  .card-stats { display: flex; gap: 0.5rem; flex-wrap: wrap; margin-bottom: 0.25rem; }
  .card-stats span { font-size: 0.6875rem; color: var(--gray-500); }

  /* KDEM bar */
  .kdem-bar {
    display: flex; align-items: center; gap: 1rem; flex-wrap: wrap;
    padding: 0.75rem 1.25rem; margin-bottom: 2rem;
    background: var(--primary-light); border: 1px solid rgba(37,99,235,0.12);
    border-radius: var(--radius);
  }
  .kdem-label { font-size: 0.875rem; font-weight: 700; color: var(--primary-dark); }
  .kdem-stats { display: flex; gap: 0.75rem; flex: 1; }
  .kdem-stats span { font-size: 0.75rem; color: var(--primary-dark); font-weight: 500; }
  .kdem-link { font-size: 0.75rem; font-weight: 700; color: var(--primary); text-decoration: none; }
  .kdem-link:hover { text-decoration: underline; }

  @media (max-width: 1024px) {
    .cards-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 768px) {
    .district-name { font-size: 1.5rem; }
    .cards-grid { grid-template-columns: 1fr; }
    .headline { gap: 0.25rem 0.75rem; }
    .hl { font-size: 0.8125rem; }
    .card { padding: 1rem; }
    .card-teaser-list li { font-size: 0.625rem; }
    .card-live { flex-direction: column; gap: 0.25rem; }
    .kdem-bar { flex-direction: column; gap: 0.5rem; }
    .kdem-stats { flex-wrap: wrap; gap: 0.5rem; }
  }
</style>
