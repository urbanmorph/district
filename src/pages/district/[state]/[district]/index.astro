---
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import DistrictMapStatic from '../../../../components/DistrictMapStatic.astro';
import { formatCurrency, formatPopulation, getStates } from '../../../../lib/data-loader';

export function getStaticPaths() {
  const states = getStates();
  return states.flatMap(s =>
    s.districts.map(d => ({
      params: { state: s.slug, district: d.id },
      props: { district: d, stateName: s.name, stateSlug: s.slug }
    }))
  );
}

const { district: d, stateName, stateSlug } = Astro.props;
const eco = d.economy || {} as any;
const demo = d.demographics || {} as any;
const roadmap = (d as any).roadmap;
const industries = (d as any).industries;
const liveData = (d as any).liveData;
const kdem = (d as any).kdem;
const communityInsights = (d as any).communityInsights;
const dataSources = (d as any).dataSources || [];
const portalUrl = `/district/${stateSlug}/${d.id}/portal`;
const discussUrl = `${portalUrl}?tab=discuss`;

// Phase 1 progress
const phase1 = roadmap?.phases?.phase1;
const phase1Progress = phase1?.progress || 0;

// Sector count + jobs
const sectorCount = industries?.sectors?.length || 0;
const totalJobs = roadmap?.jobsToCreate || industries?.overview?.totalJobs || 0;

// Next steps count
const nextStepCount = phase1?.components?.filter((c: any) => c.progress > 0 && c.progress < 100).length || 0;
---

<BaseLayout
  title={d.name}
  description={`Development briefing for ${d.name} district, ${stateName}`}
  headerTitle={`${d.name} Development Dashboard`}
  breadcrumb={[
    { label: 'India', href: '/' },
    { label: stateName, href: `/state/${stateSlug}` },
    { label: d.name }
  ]}
>
  <DistrictMapStatic slot="header-icon" districtName={d.name} stateName={stateName} size={40} />

  <!-- Cards Grid: 4-col, rows pair left (where we are) with right (where we're going) -->
  <div class="cards-grid">
    {/* Row 1: Baseline(c1) | Goals(c1) | Roadmap(c2) | Next Steps(c2) */}
    <a href={`${portalUrl}#today`} class="card card-c1 animate-up delay-1">
      <div class="card-icon">📊</div>
      <div class="card-body">
        <div class="card-title">Baseline: {d.lastUpdated?.slice(0, 4) || '2026'}</div>
        <ul class="card-lines">
          {demo.population && demo.density && <li>Population: {formatPopulation(demo.population)}, {demo.density}/km²</li>}
          {eco.perCapitaIncome && <li>Per Capita Income: {formatCurrency(eco.perCapitaIncome)}</li>}
          {eco.gddp_crores && <li>GDDP: ₹{eco.gddp_crores.toLocaleString('en-IN')} Cr</li>}
          {d.rankings?.perCapitaIncome?.stateRank && <li>State Rank: {d.rankings.perCapitaIncome.stateRank}</li>}
          {demo.literacyRate && <li>Literacy: {demo.literacyRate}%</li>}
          {eco.gddpComposition && <li>Economy: {eco.gddpComposition.services}% services, {eco.gddpComposition.agriculture}% agri, {eco.gddpComposition.industry}% industry</li>}
        </ul>
      </div>
      <span class="card-arrow">→</span>
    </a>

    {roadmap ? (
      <a href={`${portalUrl}#goals`} class="card card-c1 animate-up delay-2">
        <div class="card-icon">🎯</div>
        <div class="card-body">
          <div class="card-title">Goals: 2034</div>
          <div class="card-goals">
            {roadmap.perCapitaGoal && eco.perCapitaIncome && (
              <div class="card-goal-pair">
                <span class="goal-now">{formatCurrency(eco.perCapitaIncome)}</span>
                <span class="goal-sep">→</span>
                <span class="goal-future">{formatCurrency(roadmap.perCapitaGoal)}</span>
                <span class="goal-what">PCI</span>
              </div>
            )}
            {roadmap.targetRank && d.rankings?.perCapitaIncome?.stateRank && (
              <div class="card-goal-pair">
                <span class="goal-now">{d.rankings.perCapitaIncome.stateRank}</span>
                <span class="goal-sep">→</span>
                <span class="goal-future">{roadmap.targetRank}</span>
                <span class="goal-what">Rank</span>
              </div>
            )}
          </div>
          <ul class="card-lines">
            {roadmap.jobsToCreate && <li>Jobs target: {roadmap.jobsToCreate.toLocaleString('en-IN')}</li>}
            {roadmap.totalInvestment && <li>Investment: ₹{roadmap.totalInvestment.toLocaleString('en-IN')} Cr</li>}
            <li>HDI: target TBD</li>
          </ul>
        </div>
        <span class="card-arrow">→</span>
      </a>
    ) : <div />}

    {roadmap ? (
      <a href={`${portalUrl}?tab=data#roadmap`} class="card card-c2 animate-up delay-3">
        <div class="card-icon">🗺️</div>
        <div class="card-body">
          <div class="card-title">Strategic Roadmap</div>
          <div class="card-kpi-row">
            <span class="card-kpi">{Object.keys(roadmap.phases).length} phases</span>
            <span class="card-kpi">{phase1Progress}% Phase 1</span>
          </div>
          <div class="card-phase-bar"><div class="card-phase-fill" style={`width:${phase1Progress}%`}></div></div>
          {phase1?.components && <div class="card-teaser">{phase1.components.slice(0, 3).map((c: any) => c.name).join(' · ')}</div>}
          <div class="card-sub">{phase1?.name} · {phase1?.years} · ₹{phase1?.budget?.toLocaleString('en-IN')} Cr</div>
        </div>
        <span class="card-arrow">→</span>
      </a>
    ) : <div />}

    {nextStepCount > 0 ? (
      <a href={`${portalUrl}#nextsteps`} class="card card-c2 animate-up delay-4">
        <div class="card-icon">📋</div>
        <div class="card-body">
          <div class="card-title">Next Steps</div>
          <div class="card-kpi-row">
            <span class="card-kpi">{nextStepCount} in progress</span>
          </div>
          <ul class="card-teaser-list">
            {phase1?.components?.filter((c: any) => c.progress > 0 && c.progress < 100).slice(0, 3).map((c: any) => (
              <li>{c.name} — {c.progress}%</li>
            ))}
          </ul>
        </div>
        <span class="card-arrow">→</span>
      </a>
    ) : <div />}

    {/* Row 2: S&C(c1) | Opportunities(c1) | Industry(c2) | Community(c2) */}
    {(d.strengths?.length || d.challenges?.length) ? (
      <a href={`${portalUrl}#strengths`} class="card card-c1 animate-up delay-5">
        <div class="card-icon">⚖️</div>
        <div class="card-body">
          <div class="card-title">Strengths & Challenges</div>
          <div class="card-kpi-row">
            {d.strengths?.length > 0 && <span class="card-kpi green">✓ {d.strengths.length}</span>}
            {d.challenges?.length > 0 && <span class="card-kpi red">✗ {d.challenges.length}</span>}
          </div>
          <ul class="card-teaser-list">
            {d.strengths?.slice(0, 2).map(s => <li class="teaser-strength">✓ {s.length > 55 ? s.slice(0, 52) + '...' : s}</li>)}
            {d.challenges?.slice(0, 1).map(c => <li class="teaser-challenge">✗ {c.length > 55 ? c.slice(0, 52) + '...' : c}</li>)}
          </ul>
          {communityInsights?.count > 0 && <div class="card-badge">{communityInsights.count} community insights added</div>}
        </div>
        <span class="card-arrow">→</span>
      </a>
    ) : <div />}

    {d.opportunities?.length > 0 ? (
      <a href={`${portalUrl}#opportunities`} class="card card-c1 animate-up delay-6">
        <div class="card-icon">⚡</div>
        <div class="card-body">
          <div class="card-title">Opportunities</div>
          <div class="card-kpi-row">
            <span class="card-kpi">{d.opportunities.length} identified</span>
          </div>
          <ul class="card-teaser-list">
            {d.opportunities.slice(0, 3).map(o => <li>⚡ {o.length > 55 ? o.slice(0, 52) + '...' : o}</li>)}
          </ul>
        </div>
        <span class="card-arrow">→</span>
      </a>
    ) : <div />}

    {industries?.sectors?.length > 0 ? (
      <a href={`${portalUrl}?tab=data#industries`} class="card card-c2 animate-up">
        <div class="card-icon">🏭</div>
        <div class="card-body">
          <div class="card-title">Industry Sectors</div>
          <div class="card-kpi-row">
            <span class="card-kpi">{industries.sectors.length} sectors</span>
            {industries.overview?.totalInvestment && <span class="card-kpi">₹{industries.overview.totalInvestment.toLocaleString('en-IN')} Cr</span>}
            {industries.overview?.totalJobs && <span class="card-kpi">{industries.overview.totalJobs.toLocaleString('en-IN')} jobs</span>}
          </div>
          <div class="card-teaser">{industries.sectors.map((s: any) => s.name).join(' · ')}</div>
          {industries.overview?.status && <div class="card-sub">{industries.overview.status}</div>}
        </div>
        <span class="card-arrow">→</span>
      </a>
    ) : <div />}

    <a href={discussUrl} class="card card-c2 card-community animate-up">
      <div class="card-icon">💬</div>
      <div class="card-body">
        <div class="card-title">Community</div>
        {communityInsights?.count > 0 ? (
          <Fragment>
            <div class="card-kpi-row">
              <span class="card-kpi green">{communityInsights.count} insights added to data</span>
            </div>
            {communityInsights.contributors?.length > 0 && <div class="card-teaser">Contributors: {communityInsights.contributors.join(', ')}</div>}
          </Fragment>
        ) : (
          <div class="card-teaser">Be the first to share what you know about {d.name}</div>
        )}
        {communityInsights?.unverified?.length > 0 && <div class="card-sub">{communityInsights.unverified.length} insights awaiting verification</div>}
      </div>
      <span class="card-arrow">→</span>
    </a>
  </div>

  {/* KDEM strip — only for districts with digital economy data */}
  {kdem && (
    <div class="kdem-bar animate-up">
      <span class="kdem-label">💻 {kdem.clusterName}</span>
      <span class="kdem-stats">
        {kdem.targets2030?.startups && <span>{kdem.targets2030.startups} startups</span>}
        {kdem.targets2030?.jobs && <span>{kdem.targets2030.jobs.toLocaleString('en-IN')} jobs</span>}
        <span>by 2030</span>
      </span>
      <a href={`${portalUrl}#kdem`} class="kdem-link">View →</a>
    </div>
  )}
</BaseLayout>

<style>
  /* Cards Grid */
  .cards-grid {
    display: grid; grid-template-columns: repeat(4, 1fr);
    gap: 1rem; margin-bottom: 1.5rem; padding-top: 1.5rem;
  }

  .card {
    display: flex; align-items: flex-start; gap: 0.875rem;
    background: white; border: 1px solid var(--gray-200); border-radius: var(--radius-lg);
    padding: 1.25rem; text-decoration: none; color: inherit;
    transition: all 0.2s; position: relative;
  }
  .card:hover { border-color: var(--primary); box-shadow: var(--shadow-md); transform: translateY(-2px); }
  .card-c1 { background: #f8faff; border-left: 3px solid var(--primary-light); }
  .card-c2 { background: #f6fdf9; border-left: 3px solid var(--green-light); }
  .card-c1:hover { border-left-color: var(--primary); }
  .card-c2:hover { border-left-color: var(--green); }
  .card-icon { font-size: 1.375rem; flex-shrink: 0; margin-top: 0.125rem; }
  .card-body { flex: 1; min-width: 0; }
  .card-title { font-size: 0.9375rem; font-weight: 700; color: var(--gray-800); margin-bottom: 0.5rem; }
  .card-kpi-row { display: flex; gap: 0.5rem; flex-wrap: wrap; margin-bottom: 0.375rem; }
  .card-kpi {
    font-size: 0.8125rem; font-weight: 800; color: var(--gray-900);
    background: var(--gray-100); padding: 0.1875rem 0.5rem; border-radius: 4px;
  }
  .card-kpi.green { color: var(--green-dark); background: var(--green-light); }
  .card-kpi.red { color: var(--red-dark); background: var(--red-light); }
  .card-sub { font-size: 0.75rem; color: var(--gray-400); line-height: 1.4; }
  .card-lines { list-style: none; margin: 0; }
  .card-lines li { font-size: 0.8125rem; color: var(--gray-600); line-height: 1.7; }
  .card-teaser { font-size: 0.75rem; color: var(--gray-500); line-height: 1.4; margin-bottom: 0.25rem; }
  .card-teaser-list { list-style: none; margin: 0.25rem 0; }
  .card-teaser-list li { font-size: 0.75rem; color: var(--gray-600); line-height: 1.5; }
  .teaser-strength { color: var(--green-dark); }
  .teaser-challenge { color: var(--red-dark); }

  /* Goals mini */
  .card-goals { display: flex; flex-direction: column; gap: 0.25rem; margin-bottom: 0.25rem; }
  .card-goal-pair { display: flex; align-items: center; gap: 0.375rem; font-size: 0.8125rem; }
  .goal-now { color: var(--gray-500); font-weight: 700; }
  .goal-sep { color: var(--gray-900); font-weight: 800; }
  .goal-future { color: var(--primary); font-weight: 800; }
  .goal-what { color: var(--gray-400); font-size: 0.625rem; text-transform: uppercase; letter-spacing: 0.04em; }

  /* Phase bar mini */
  .card-phase-bar { height: 5px; background: var(--gray-100); border-radius: 3px; overflow: hidden; margin: 0.5rem 0; }
  .card-phase-fill { height: 100%; border-radius: 3px; background: linear-gradient(90deg, var(--primary), var(--teal)); }
  .card-badge {
    font-size: 0.625rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.04em;
    color: var(--green-dark); background: var(--green-light);
    padding: 0.1875rem 0.5rem; border-radius: 3px; display: inline-block; margin-top: 0.25rem;
  }
  .card-arrow {
    font-size: 1.125rem; color: var(--gray-300); flex-shrink: 0;
    transition: color 0.2s; margin-top: 0.125rem;
  }
  .card:hover .card-arrow { color: var(--primary); }

  /* Live data in card */
  .card-live { display: flex; align-items: center; gap: 0.625rem; margin-top: 0.5rem; }
  .live-dot { width: 6px; height: 6px; border-radius: 50%; background: var(--green); flex-shrink: 0; }
  .card-live-item { font-size: 0.75rem; color: var(--gray-500); }
  .card-live-item .up { color: var(--green); font-weight: 700; }
  .card-live-item .down { color: var(--red); font-weight: 700; }
  .card-stats { display: flex; gap: 0.5rem; flex-wrap: wrap; margin-bottom: 0.25rem; }
  .card-stats span { font-size: 0.75rem; color: var(--gray-500); }

  /* KDEM bar */
  .kdem-bar {
    display: flex; align-items: center; gap: 1rem; flex-wrap: wrap;
    padding: 0.75rem 1.25rem; margin-bottom: 2rem;
    background: var(--primary-light); border: 1px solid rgba(37,99,235,0.12);
    border-radius: var(--radius);
  }
  .kdem-label { font-size: 0.875rem; font-weight: 700; color: var(--primary-dark); }
  .kdem-stats { display: flex; gap: 0.75rem; flex: 1; }
  .kdem-stats span { font-size: 0.75rem; color: var(--primary-dark); font-weight: 500; }
  .kdem-link { font-size: 0.75rem; font-weight: 700; color: var(--primary); text-decoration: none; }
  .kdem-link:hover { text-decoration: underline; }

  @media (max-width: 1024px) {
    .cards-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 768px) {
    .district-name { font-size: 1.5rem; }
    .cards-grid { grid-template-columns: 1fr; }
    .headline { gap: 0.25rem 0.75rem; }
    .hl { font-size: 0.8125rem; }
    .card { padding: 1rem; }
    .card-teaser-list li { font-size: 0.625rem; }
    .card-live { flex-direction: column; gap: 0.25rem; }
    .kdem-bar { flex-direction: column; gap: 0.5rem; }
    .kdem-stats { flex-wrap: wrap; gap: 0.5rem; }
  }
</style>
