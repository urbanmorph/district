---
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import DistrictMapStatic from '../../../../components/DistrictMapStatic.astro';
import DistrictSection from '../../../../components/DistrictSection.astro';
import Roadmap from '../../../../components/Roadmap.astro';
import RoleSwitcher from '../../../../components/RoleSwitcher.astro';
import Discussion from '../../../../components/Discussion.astro';
import RoleDashboard from '../../../../components/RoleDashboard.astro';
import { formatCurrency, formatPopulation, getStates } from '../../../../lib/data-loader';
import { getAvailableRoles } from '../../../../lib/roles';

export function getStaticPaths() {
  const states = getStates();
  return states.flatMap(s =>
    s.districts.map(d => ({
      params: { state: s.slug, district: d.id },
      props: { district: d, stateName: s.name, stateSlug: s.slug }
    }))
  );
}

const { district: d, stateName, stateSlug } = Astro.props;
const eco = d.economy || {} as any;
const demo = d.demographics || {} as any;
const comp = eco.gddpComposition || {};
const roadmap = (d as any).roadmap;
const industries = (d as any).industries;
const fpos = (d as any).fpos;
const industrialLand = (d as any).industrialLand;
const creditData = (d as any).creditData;
const msme = (d as any).msme;
const investments = (d as any).investments;
const liveData = (d as any).liveData;
const kdem = (d as any).kdem;
const communityInsights = (d as any).communityInsights;
const communityItems: string[] = communityInsights?.verifiedItems || [];
const roleDashboards = (d as any).roleDashboards || {};
const districtAlerts = (d as any).alerts || [];
const availableRoles = getAvailableRoles(d);

function fmtCr(v: number) { return `₹${v.toLocaleString('en-IN')} Cr`; }
function fmtNum(v: number) { return v.toLocaleString('en-IN'); }
function fmtRs(v: number) {
  if (v >= 10000000) return `₹${(v / 10000000).toFixed(1)} Cr`;
  if (v >= 100000) return `₹${(v / 100000).toFixed(1)}L`;
  return `₹${v.toLocaleString('en-IN')}`;
}
function isCommunity(text: string): boolean {
  return communityItems.some(item => text.toLowerCase().includes(item.toLowerCase()));
}

// Phase data for goals/next steps
const phases = roadmap ? Object.keys(roadmap.phases).sort().map(k => ({ id: k, ...roadmap.phases[k] })) : [];
const phase1 = phases.length > 0 ? phases[0] : null;
const nextSteps = phase1?.components?.filter((c: any) => c.progress > 0 && c.progress < 100) || [];
---

<BaseLayout
  title={`${d.name} Portal`}
  description={`Detailed development portal for ${d.name} district, ${stateName}`}
  headerTitle={`${d.name} Development Portal`}
  breadcrumb={[
    { label: 'India', href: '/' },
    { label: stateName, href: `/state/${stateSlug}` },
    { label: d.name, href: `/district/${stateSlug}/${d.id}` },
    { label: 'Portal' }
  ]}
>
  <DistrictMapStatic slot="header-icon" districtName={d.name} stateName={stateName} size={40} />

  <!-- Portal Tabs -->
  <div class="portal-tabs" id="portal-tabs">
    <button class="portal-tab active" data-tab="today">Baseline</button>
    <button class="portal-tab" data-tab="data">Dashboard</button>
    <button class="portal-tab" data-tab="discuss">Discussion</button>
    <button class="portal-tab" data-tab="sources">Sources</button>
  </div>

  <!-- Today Tab -->
  <div class="portal-tab-content active" id="tab-today">

  <!-- ① Today -->
  <div id="today" class="portal-section">
    <h3 class="section-title">{d.name} Baseline</h3>

    {/* KPI strip */}
    <div class="kpi-strip" style="margin-bottom:1.25rem;">
      {eco.perCapitaIncome && (
        <div class="kpi-card">
          <div class="kpi-accent" style="background:var(--teal);"></div>
          <div class="kpi-value">{formatCurrency(eco.perCapitaIncome)}</div>
          <div class="kpi-label">Per Capita Income</div>
          {d.rankings?.perCapitaIncome?.stateRank && <div class="kpi-trend negative">Rank {d.rankings.perCapitaIncome.stateRank} in {stateName}</div>}
        </div>
      )}
      {eco.gddp_crores && (
        <div class="kpi-card">
          <div class="kpi-accent" style="background:var(--primary);"></div>
          <div class="kpi-value">₹{eco.gddp_crores.toLocaleString('en-IN')} Cr</div>
          <div class="kpi-label">GDDP</div>
        </div>
      )}
      {demo.population && (
        <div class="kpi-card">
          <div class="kpi-accent" style="background:var(--orange);"></div>
          <div class="kpi-value">{formatPopulation(demo.population)}</div>
          <div class="kpi-label">Population</div>
        </div>
      )}
      {demo.density && (
        <div class="kpi-card">
          <div class="kpi-accent" style="background:var(--green);"></div>
          <div class="kpi-value">{demo.density}/km²</div>
          <div class="kpi-label">Density</div>
        </div>
      )}
    </div>

    {/* GDDP + Demographics */}
    {(comp.agriculture || comp.industry || comp.services || demo.population) && (
      <div class="today-two-col">
        {(comp.agriculture || comp.industry || comp.services) && (
          <div class="panel">
            <h4 class="portal-sub-title">GDDP Composition</h4>
            <div class="today-donut-row">
              <div class="today-donut">
                <svg viewBox="0 0 140 140">
                  {(() => {
                    const r = 54, c = 2 * Math.PI * r;
                    const servLen = ((comp.services || 0) / 100) * c;
                    const indLen = ((comp.industry || 0) / 100) * c;
                    const agriLen = ((comp.agriculture || 0) / 100) * c;
                    return [
                      { color: 'var(--teal)', len: servLen, offset: 0 },
                      { color: 'var(--primary)', len: indLen, offset: -servLen },
                      { color: 'var(--green)', len: agriLen, offset: -(servLen + indLen) },
                    ].map(seg => (
                      <circle fill="none" stroke={seg.color} stroke-width="22" cx="70" cy="70" r={r}
                        stroke-dasharray={`${seg.len} ${c - seg.len}`}
                        stroke-dashoffset={seg.offset} />
                    ));
                  })()}
                </svg>
                <div class="today-donut-center">
                  <span class="today-donut-val">{eco.gddp_crores ? `₹${(eco.gddp_crores/1000).toFixed(0)}K` : ''}</span>
                  <span class="today-donut-unit">Cr</span>
                </div>
              </div>
              <div class="today-legend">
                <div><span class="today-dot" style="background:var(--teal)"></span> Services {comp.services}%</div>
                <div><span class="today-dot" style="background:var(--green)"></span> Agriculture {comp.agriculture}%</div>
                <div><span class="today-dot" style="background:var(--primary)"></span> Industry {comp.industry}%</div>
              </div>
            </div>
          </div>
        )}
        {demo.population && (
          <div class="panel">
            <h4 class="portal-sub-title">Demographics</h4>
            <div class="today-demo">
              {demo.area_sq_km && <div class="today-demo-row"><span>Area</span><strong>{demo.area_sq_km.toLocaleString('en-IN')} km²</strong></div>}
              {demo.rural && demo.population && <div class="today-demo-row"><span>Rural / Urban</span><strong>{((demo.rural/demo.population)*100).toFixed(1)}% / {((demo.urban/demo.population)*100).toFixed(1)}%</strong></div>}
              {demo.literacyRate && <div class="today-demo-row"><span>Literacy</span><strong>{demo.literacyRate}%</strong></div>}
              {demo.sexRatio && <div class="today-demo-row"><span>Sex Ratio</span><strong>{demo.sexRatio} per 1000</strong></div>}
              {eco.growthRate && <div class="today-demo-row"><span>Growth Rate</span><strong>{eco.growthRate}%</strong></div>}
            </div>
          </div>
        )}
      </div>
    )}

  </div>

  <!-- Live Data -->
  {liveData && (
    <div id="livedata" class="portal-section alt">
      <h3 class="section-title">Live Data <span class="live-badge">Snapshot</span></h3>
      <div class="live-data-grid">
        {liveData.commodityPrices && (
          <div class="panel">
            <h4 class="detail-block-title">Commodity Prices</h4>
            {Object.entries(liveData.commodityPrices).map(([key, data]: [string, any]) => (
              <div class="commodity-item">
                <div class="commodity-header">
                  <span class="commodity-name">{key.replace(/([A-Z])/g, ' $1').trim()}</span>
                  <span class="commodity-price">{data.unit === 'Rs/quintal' ? `₹${fmtNum(data.price)}/q` : `₹${fmtNum(data.price)}`}</span>
                </div>
                <div class="commodity-meta">
                  <span class="commodity-market">{data.market}</span>
                  {data.percentChange !== undefined && (
                    <span class={`commodity-change ${data.percentChange >= 0 ? 'positive' : 'negative'}`}>
                      {data.percentChange >= 0 ? '+' : ''}{data.percentChange}%
                    </span>
                  )}
                </div>
              </div>
            ))}
          </div>
        )}
        {liveData.rainfall && (
          <div class="panel">
            <h4 class="detail-block-title">Rainfall</h4>
            <div class="rainfall-grid">
              {liveData.rainfall.today && <div class="rainfall-item"><span class="rainfall-label">Today</span><span class="rainfall-value">{liveData.rainfall.today.amount} mm</span></div>}
              {liveData.rainfall.thisWeek && <div class="rainfall-item"><span class="rainfall-label">This week</span><span class="rainfall-value">{liveData.rainfall.thisWeek.amount} mm</span></div>}
              {liveData.rainfall.thisMonth && (
                <div class="rainfall-item">
                  <span class="rainfall-label">This month</span>
                  <span class="rainfall-value">{liveData.rainfall.thisMonth.amount} mm</span>
                  {liveData.rainfall.thisMonth.deviation !== undefined && <span class={`rainfall-deviation ${liveData.rainfall.thisMonth.deviation >= 0 ? 'positive' : 'negative'}`}>{liveData.rainfall.thisMonth.deviation >= 0 ? '+' : ''}{liveData.rainfall.thisMonth.deviation}%</span>}
                </div>
              )}
              {liveData.rainfall.thisSeason && (
                <div class="rainfall-item">
                  <span class="rainfall-label">This season</span>
                  <span class="rainfall-value">{liveData.rainfall.thisSeason.amount} mm (normal: {liveData.rainfall.thisSeason.normalAmount})</span>
                  {liveData.rainfall.thisSeason.status && <span class={`rainfall-status status-${liveData.rainfall.thisSeason.status.toLowerCase()}`}>{liveData.rainfall.thisSeason.status}</span>}
                </div>
              )}
            </div>
          </div>
        )}
      </div>
    </div>
  )}

  <!-- ② Strengths & Challenges -->
  {(d.strengths?.length || d.challenges?.length) && (
    <div id="strengths" class="portal-section">
      <h3 class="section-title">Strengths & Challenges</h3>
      <div class="sc-two-col">
        {d.strengths?.length > 0 && (
          <div class="panel sc-panel">
            <div class="sc-header sc-green">What's working</div>
            <ul class="sc-items">
              {d.strengths.map(s => (
                <li><span class="sc-mark sc-check">✓</span>{s}{isCommunity(s) && <span class="community-pill">community</span>}</li>
              ))}
            </ul>
          </div>
        )}
        {d.challenges?.length > 0 && (
          <div class="panel sc-panel">
            <div class="sc-header sc-red">What needs attention</div>
            <ul class="sc-items">
              {d.challenges.map(c => (
                <li><span class="sc-mark sc-cross">✗</span>{c}{isCommunity(c) && <span class="community-pill">community</span>}</li>
              ))}
            </ul>
          </div>
        )}
      </div>
    </div>
  )}

  <!-- ③ Opportunities (links to industries section below) -->
  {d.opportunities?.length > 0 && (
    <div id="opportunities" class="portal-section alt">
      <h3 class="section-title">Opportunities</h3>
      <div class="panel">
        <ul class="opp-items">
          {d.opportunities.map(o => (
            <li><span class="opp-bolt">⚡</span>{o}{isCommunity(o) && <span class="community-pill">community</span>}</li>
          ))}
        </ul>
      </div>
    </div>
  )}

  <!-- ④ Goals -->
  {roadmap && (
    <div id="goals" class="portal-section">
      <h3 class="section-title">Goals</h3>
      <div class="goals-row">
        {roadmap.perCapitaGoal && eco.perCapitaIncome && (
          <div class="panel goal-card">
            <div class="goal-from">{formatCurrency(eco.perCapitaIncome)}</div>
            <div class="goal-arrow">→</div>
            <div class="goal-to">{formatCurrency(roadmap.perCapitaGoal)}</div>
            <div class="goal-label">Per Capita Income</div>
          </div>
        )}
        {roadmap.targetRank && d.rankings?.perCapitaIncome?.stateRank && (
          <div class="panel goal-card">
            <div class="goal-from">{d.rankings.perCapitaIncome.stateRank}</div>
            <div class="goal-arrow">→</div>
            <div class="goal-to">{roadmap.targetRank}</div>
            <div class="goal-label">State Rank</div>
          </div>
        )}
        {roadmap.jobsToCreate && (
          <div class="panel goal-card">
            <div class="goal-to">{fmtNum(roadmap.jobsToCreate)}</div>
            <div class="goal-label">New Jobs Target</div>
          </div>
        )}
        {roadmap.totalInvestment && (
          <div class="panel goal-card">
            <div class="goal-to">{fmtCr(roadmap.totalInvestment)}</div>
            <div class="goal-label">Investment Target</div>
          </div>
        )}
      </div>
    </div>
  )}

  <!-- ⑥ Next Steps -->
  {nextSteps.length > 0 && (
    <div id="nextsteps" class="portal-section alt">
      <h3 class="section-title">Next Steps</h3>
      <div class="panel">
        {nextSteps.map((step: any) => (
          <div class="nextstep-item">
            <div class="nextstep-header">
              <span class="nextstep-name">{step.name}</span>
              <span class="nextstep-pct">{step.progress}%</span>
            </div>
            <div class="nextstep-bar"><div class="nextstep-fill" style={`width:${step.progress}%`}></div></div>
            {step.items?.length > 0 && (
              <ul class="nextstep-tasks">
                {step.items.slice(0, 3).map((item: string) => <li>{item}</li>)}
              </ul>
            )}
          </div>
        ))}
      </div>
    </div>
  )}


  </div><!-- /tab-today -->

  <!-- Dashboard Tab -->
  <div class="portal-tab-content" id="tab-data" style="display:none;">

  <!-- Role Switcher -->
  {availableRoles.length > 1 && (
    <RoleSwitcher roles={availableRoles} activeRole={null} />
  )}
  <script type="application/json" id="roles-data" set:html={JSON.stringify(availableRoles)} />

  <!-- Role Selector (shown when no role selected) -->
  <div id="role-no-selection" class="portal-section">
    <h3 class="section-title">Who's In Charge?</h3>
    <p class="role-selector-desc">Select a role to see a dashboard customized for their responsibilities.</p>
    <div class="role-selector-grid">
      {availableRoles.filter(r => r.id !== 'full').map(role => (
        <button class="role-card" data-select-role={role.id}>
          <span class="role-card-icon">{role.icon}</span>
          <span class="role-card-name">{role.name}</span>
          <span class="role-card-desc">{role.description}</span>
          <span class="role-card-arrow">Select →</span>
        </button>
      ))}
    </div>
  </div>

  <!-- Pre-rendered role dashboards (hidden, toggled by JS) -->
  {availableRoles.filter(r => r.id !== 'full' && roleDashboards[r.id]).map(role => (
    <div data-role-dashboard={role.id} style="display:none;" class="portal-section">
      <RoleDashboard
        role={role}
        dashData={roleDashboards[role.id]}
        alerts={districtAlerts.filter((a: any) => a.roles.includes(role.id))}
        roadmap={roadmap}
        liveData={liveData}
        portalUrl={`/district/${stateSlug}/${d.id}/portal`}
      />
    </div>
  ))}

  <!-- Fallback for roles without custom dashboards -->
  {availableRoles.filter(r => r.id !== 'full' && !roleDashboards[r.id]).map(role => (
    <div data-role-dashboard={role.id} style="display:none;" class="portal-section">
      <div class="rd-fallback">
        <span class="rd-fallback-icon">{role.icon}</span>
        <h3>{role.name}</h3>
        <p>Custom dashboard not yet available for this district. Showing filtered data below.</p>
      </div>
    </div>
  ))}

  <!-- Existing filtered sections (shown below dashboard) -->
  <!-- ⑤ Development Roadmap -->
  {roadmap && (
    <div id="roadmap">
      <DistrictSection section="roadmap">
        <div class="panel animate-up portal-section">
          <Roadmap roadmap={roadmap} activeRole={null} />
        </div>
      </DistrictSection>
    </div>
  )}

  <!-- Industries — Full Detail -->
  {industries?.sectors?.length > 0 && (
    <div id="industries"><DistrictSection section="industries">
      <section class="animate-up portal-section">
        <h3 class="section-title">Industry Sectors</h3>

        {/* Overview stats */}
        {industries.overview && (
          <div class="panel" style="margin-bottom:1.25rem;">
            <div class="portal-stats-row">
              {industries.overview.totalInvestment && <div class="portal-stat"><span class="portal-stat-value">{fmtCr(industries.overview.totalInvestment)}</span><span class="portal-stat-label">Investment Pipeline</span></div>}
              {industries.overview.totalJobs && <div class="portal-stat"><span class="portal-stat-value">{fmtNum(industries.overview.totalJobs)}</span><span class="portal-stat-label">Jobs Target</span></div>}
              {industries.overview.gddpContribution && <div class="portal-stat"><span class="portal-stat-value">{fmtCr(industries.overview.gddpContribution)}</span><span class="portal-stat-label">GDDP Contribution</span></div>}
              {industries.overview.status && <div class="portal-stat"><span class="portal-stat-value">{industries.overview.status}</span><span class="portal-stat-label">Status</span></div>}
            </div>
          </div>
        )}

        {/* Sector cards — full detail */}
        {industries.sectors.map((sector: any) => (
          <div class="panel sector-detail-card">
            <div class="sector-detail-header">
              <div>
                <h4 class="sector-detail-name">{sector.name}</h4>
                {sector.priorityNote && <p class="sector-detail-note">{sector.priorityNote}</p>}
              </div>
              {sector.priority && (
                <span class={`priority-badge priority-${sector.priority.toLowerCase().replace(/[^a-z]/g, '')}`}>{sector.priority}</span>
              )}
            </div>

            <div class="sector-detail-grid">
              {/* Investment */}
              {sector.investment && (
                <div class="detail-block">
                  <h5 class="detail-block-title">Investment</h5>
                  <div class="detail-value-large">{fmtCr(sector.investment.total)}</div>
                  {sector.investment.breakdown && (
                    <div class="detail-breakdown">
                      {Object.entries(sector.investment.breakdown).map(([k, v]: [string, any]) => (
                        <div class="detail-row"><span class="detail-row-label">{k}</span><span class="detail-row-value">{fmtCr(v)}</span></div>
                      ))}
                    </div>
                  )}
                  {sector.investment.financing && (
                    <div class="detail-breakdown" style="margin-top:0.5rem;">
                      <div class="detail-sub-title">Financing</div>
                      {Object.entries(sector.investment.financing).map(([k, v]: [string, any]) => (
                        <div class="detail-row"><span class="detail-row-label">{k}</span><span class="detail-row-value">{fmtCr(v)}</span></div>
                      ))}
                    </div>
                  )}
                </div>
              )}

              {/* Jobs */}
              {sector.impact?.jobs && (
                <div class="detail-block">
                  <h5 class="detail-block-title">Employment Impact</h5>
                  <div class="detail-value-large">{fmtNum(sector.impact.jobs.total)} jobs</div>
                  <div class="detail-breakdown">
                    <div class="detail-row"><span class="detail-row-label">Direct</span><span class="detail-row-value">{fmtNum(sector.impact.jobs.direct)}</span></div>
                    <div class="detail-row"><span class="detail-row-label">Indirect</span><span class="detail-row-value">{fmtNum(sector.impact.jobs.indirect)}</span></div>
                    {sector.impact.jobs.skillLevel && <div class="detail-row"><span class="detail-row-label">Skill</span><span class="detail-row-value">{sector.impact.jobs.skillLevel}</span></div>}
                    {sector.impact.jobs.salary && <div class="detail-row"><span class="detail-row-label">Salary</span><span class="detail-row-value">{sector.impact.jobs.salary}</span></div>}
                  </div>
                </div>
              )}

              {/* Revenue */}
              {sector.impact?.revenue && (
                <div class="detail-block">
                  <h5 class="detail-block-title">Revenue (2034)</h5>
                  <div class="detail-value-large">{fmtCr(sector.impact.revenue.year2034)}</div>
                  {sector.impact.revenue.exportPercent && (
                    <div class="detail-breakdown">
                      <div class="detail-row"><span class="detail-row-label">Export share</span><span class="detail-row-value">{sector.impact.revenue.exportPercent}%</span></div>
                    </div>
                  )}
                </div>
              )}

              {/* Timeline */}
              {sector.timeline && (
                <div class="detail-block">
                  <h5 class="detail-block-title">Timeline</h5>
                  <div class="detail-breakdown">
                    {Object.entries(sector.timeline).filter(([k]) => k.startsWith('phase')).map(([k, v]: [string, any]) => (
                      <div class="detail-row timeline-row"><span class="detail-row-value">{v}</span></div>
                    ))}
                    {sector.timeline.firstRevenue && <div class="detail-row"><span class="detail-row-label">First revenue</span><span class="detail-row-value">{sector.timeline.firstRevenue}</span></div>}
                  </div>
                </div>
              )}
            </div>

            {/* Products */}
            {sector.products?.length > 0 && (
              <div class="detail-section">
                <h5 class="detail-block-title">Products</h5>
                <div class="detail-chips">{sector.products.map((p: string) => <span class="detail-chip">{p}</span>)}</div>
              </div>
            )}

            {/* Buyers */}
            {sector.buyers && (
              <div class="detail-section">
                <h5 class="detail-block-title">Target Buyers</h5>
                <div class="buyers-grid">
                  {Object.entries(sector.buyers).map(([category, list]: [string, any]) => (
                    <div class="buyer-group">
                      <span class="buyer-category">{category}</span>
                      <span class="buyer-list">{list.join(', ')}</span>
                    </div>
                  ))}
                </div>
              </div>
            )}

            {/* Risks */}
            {sector.risks?.length > 0 && (
              <div class="detail-section">
                <h5 class="detail-block-title">Risks</h5>
                <div class="risks-list">
                  {sector.risks.map((r: any) => (
                    <div class="risk-item">
                      <span class={`risk-severity severity-${r.severity}`}>{r.severity}</span>
                      <div class="risk-content">
                        <span class="risk-text">{r.risk}</span>
                        <span class="risk-mitigation">{r.mitigation}</span>
                      </div>
                    </div>
                  ))}
                </div>
              </div>
            )}

            {/* Footer: confidence + recommendation */}
            <div class="sector-detail-footer">
              {sector.confidence && <span class="sector-confidence">{sector.confidence}</span>}
              {sector.location && <span class="sector-location">{sector.location}</span>}
            </div>
            {sector.recommendation && <p class="sector-recommendation">{sector.recommendation}</p>}
          </div>
        ))}

        {/* Comparison table */}
        {industries.comparison?.length > 0 && (
          <div class="panel" style="padding:0; overflow:hidden;">
            <h4 class="comparison-title">Sector Comparison</h4>
            <div class="table-scroll">
              <table class="portal-table">
                <thead>
                  <tr>
                    <th>Sector</th>
                    <th>Investment</th>
                    <th>Direct Jobs</th>
                    <th>Revenue 2034</th>
                    <th>GDDP %</th>
                    <th>Time to Revenue</th>
                    <th>Risk</th>
                  </tr>
                </thead>
                <tbody>
                  {industries.comparison.map((row: any) => (
                    <tr>
                      <td class="table-name">{row.industry}</td>
                      <td>{fmtCr(row.investment_crores)}</td>
                      <td>{fmtNum(row.directJobs)}</td>
                      <td>{fmtCr(row.revenue2034_crores)}</td>
                      <td>{row.gddpPercent}%</td>
                      <td>{row.timeToRevenue}</td>
                      <td>{row.risk}</td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
          </div>
        )}
      </section>
    </DistrictSection></div>
  )}

  <!-- KDEM / Beyond Bengaluru -->
  {kdem && (
    <div id="kdem"><DistrictSection section="kdem">
      <section class="animate-up portal-section">
        <h3 class="section-title">Digital Economy — Beyond Bengaluru</h3>

        <div class="panel" style="margin-bottom:1.25rem; border-top: 3px solid var(--primary);">
          <div class="kdem-header">
            <div>
              <h4 class="kdem-cluster-name">{kdem.clusterName}</h4>
              <p class="kdem-brand">{kdem.brandPosition}</p>
            </div>
            <span class={`kdem-tier tier-${kdem.tier}`}>Tier {kdem.tier} — {kdem.tierLabel}</span>
          </div>

          <div class="portal-stats-row" style="margin-top:1rem;">
            {kdem.targets2030?.startups && (
              <div class="portal-stat">
                <span class="portal-stat-value">{kdem.targets2030.startups}</span>
                <span class="portal-stat-label">Startups (2030 Target)</span>
              </div>
            )}
            {kdem.targets2030?.jobs && (
              <div class="portal-stat">
                <span class="portal-stat-value">{fmtNum(kdem.targets2030.jobs)}</span>
                <span class="portal-stat-label">Jobs (2030 Target)</span>
              </div>
            )}
            {kdem.targets2030?.digitalRevenue_crores && (
              <div class="portal-stat">
                <span class="portal-stat-value">{fmtCr(kdem.targets2030.digitalRevenue_crores)}</span>
                <span class="portal-stat-label">Digital Revenue Target</span>
              </div>
            )}
            {kdem.landCostMultiplier && (
              <div class="portal-stat">
                <span class="portal-stat-value">{kdem.landCostMultiplier}x</span>
                <span class="portal-stat-label">Land Cost vs Bengaluru</span>
              </div>
            )}
          </div>
        </div>

        {/* Current Traction */}
        {kdem.currentTraction && (
          <div class="panel" style="margin-bottom:1rem;">
            <h4 class="detail-block-title" style="margin-bottom:0.75rem;">Current Traction ({kdem.currentTraction.period})</h4>
            <div class="portal-stats-row">
              <div class="portal-stat">
                <span class="portal-stat-value">{kdem.currentTraction.newCompanies}</span>
                <span class="portal-stat-label">New Companies</span>
              </div>
              {kdem.currentTraction.expandedCompanies && (
                <div class="portal-stat">
                  <span class="portal-stat-value">{kdem.currentTraction.expandedCompanies}</span>
                  <span class="portal-stat-label">Expanded</span>
                </div>
              )}
              <div class="portal-stat">
                <span class="portal-stat-value">{fmtNum(kdem.currentTraction.jobsCreated)}</span>
                <span class="portal-stat-label">Jobs Created</span>
              </div>
            </div>
          </div>
        )}

        {/* Vertical Focus + Anchors */}
        <div class="panel" style="margin-bottom:1rem;">
          <div class="kdem-two-col">
            <div>
              <h4 class="detail-block-title">Focus Verticals</h4>
              <div class="kdem-tags">
                {kdem.verticalFocus.map((v: string) => (
                  <span class="kdem-tag">{v}</span>
                ))}
              </div>
            </div>
            {kdem.anchorCompanies?.length > 0 && (
              <div>
                <h4 class="detail-block-title">Anchor Companies</h4>
                {kdem.anchorCompanies.map((c: any) => (
                  <div class="kdem-anchor">
                    <span class="kdem-anchor-name">{c.name}</span>
                    <span class={`kdem-anchor-status status-${c.status.toLowerCase()}`}>{c.status}</span>
                  </div>
                ))}
              </div>
            )}
          </div>
        </div>

        {/* LEAP Incubation */}
        {kdem.leapIncubation?.active && (
          <div class="panel" style="margin-bottom:1rem;">
            <h4 class="detail-block-title" style="margin-bottom:0.5rem;">LEAP Agritech Incubation</h4>
            <div class="portal-stats-row">
              <div class="portal-stat">
                <span class="portal-stat-value">{fmtCr(kdem.leapIncubation.fund_crores)}</span>
                <span class="portal-stat-label">Fund Size</span>
              </div>
              <div class="portal-stat">
                <span class="portal-stat-value">{kdem.leapIncubation.duration}</span>
                <span class="portal-stat-label">Duration</span>
              </div>
              <div class="portal-stat">
                <span class="portal-stat-value">{kdem.leapIncubation.focus}</span>
                <span class="portal-stat-label">Focus</span>
              </div>
            </div>
          </div>
        )}

        {/* Digital Proximity */}
        {kdem.digitalProximity?.length > 0 && (
          <div class="panel" style="margin-bottom:1rem;">
            <h4 class="detail-block-title" style="margin-bottom:0.5rem;">Digital Proximity Advantages</h4>
            <ul class="kdem-proximity-list">
              {kdem.digitalProximity.map((item: string) => (
                <li>{item}</li>
              ))}
            </ul>
          </div>
        )}

        {/* Policies */}
        {kdem.policies?.length > 0 && (
          <div class="panel" style="margin-bottom:1rem;">
            <h4 class="detail-block-title" style="margin-bottom:0.5rem;">Applicable Policies</h4>
            {kdem.policies.map((p: any) => (
              <div class="kdem-policy">
                <span class="kdem-policy-name">{p.name}</span>
                <span class="kdem-policy-relevance">{p.relevance}</span>
              </div>
            ))}
          </div>
        )}

        {/* Link to KDEM dashboard */}
        {kdem.dashboardUrl && (
          <a href={kdem.dashboardUrl} target="_blank" rel="noopener" class="kdem-dashboard-link">
            View full KDEM dashboard &rarr;
          </a>
        )}
      </section>
    </DistrictSection></div>
  )}

  <!-- FPOs -->
  {fpos && (
    <DistrictSection section="fpos">
      <section class="animate-up portal-section">
        <h3 class="section-title">Farmer Producer Organisations</h3>
        <div class="panel" style="margin-bottom:1.25rem;">
          <div class="portal-stats-row">
            {fpos.summary && <>
              <div class="portal-stat"><span class="portal-stat-value">{fpos.summary.totalFPOs}</span><span class="portal-stat-label">Total FPOs</span></div>
              <div class="portal-stat"><span class="portal-stat-value">{fpos.summary.activeFPOs}</span><span class="portal-stat-label">Active</span></div>
              <div class="portal-stat"><span class="portal-stat-value">{fpos.summary.targetBy2032}</span><span class="portal-stat-label">Target (2032)</span></div>
              <div class="portal-stat"><span class="portal-stat-value">{fpos.summary.percentComplete}%</span><span class="portal-stat-label">Progress</span></div>
            </>}
            {fpos.financialMetrics && <>
              <div class="portal-stat"><span class="portal-stat-value">{fmtNum(fpos.financialMetrics.totalMemberFarmers)}</span><span class="portal-stat-label">Member Farmers</span></div>
              <div class="portal-stat"><span class="portal-stat-value">{fmtRs(fpos.financialMetrics.totalAnnualTurnover)}</span><span class="portal-stat-label">Annual Turnover</span></div>
            </>}
          </div>
        </div>

        {fpos.fpoDetails?.length > 0 && (
          <div class="panel" style="padding:0; overflow:hidden;">
            <div class="table-scroll">
              <table class="portal-table">
                <thead>
                  <tr>
                    <th>Name</th>
                    <th>Location</th>
                    <th>Commodities</th>
                    <th>Members</th>
                    <th>Turnover</th>
                    <th>Status</th>
                  </tr>
                </thead>
                <tbody>
                  {fpos.fpoDetails.map((fpo: any) => (
                    <tr>
                      <td class="table-name">{fpo.name}</td>
                      <td>{fpo.location}</td>
                      <td>{fpo.commodities?.join(', ')}</td>
                      <td>{fmtNum(fpo.memberFarmers)}</td>
                      <td>{fpo.annualTurnover ? fmtRs(fpo.annualTurnover) : '-'}</td>
                      <td><span class={`status-badge status-${fpo.status.toLowerCase().replace(/\s/g, '-')}`}>{fpo.status}</span></td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
          </div>
        )}
      </section>
    </DistrictSection>
  )}

  <!-- Industrial Land -->
  {industrialLand && (
    <DistrictSection section="industrial-land">
      <section class="animate-up portal-section">
        <h3 class="section-title">Industrial Land</h3>

        {industrialLand.summary && (
          <div class="panel" style="margin-bottom:1.25rem;">
            <div class="portal-stats-row">
              <div class="portal-stat"><span class="portal-stat-value">{fmtNum(industrialLand.summary.totalIndustrialLand)} acres</span><span class="portal-stat-label">Total Industrial Land</span></div>
              <div class="portal-stat"><span class="portal-stat-value">{fmtNum(industrialLand.summary.availableForAllotment)} acres</span><span class="portal-stat-label">Available</span></div>
              <div class="portal-stat"><span class="portal-stat-value">{fmtNum(industrialLand.summary.pipelineLandRequirement)} acres</span><span class="portal-stat-label">Pipeline Requirement</span></div>
              <div class="portal-stat"><span class="portal-stat-value">{fmtNum(industrialLand.summary.pipelineLandGap)} acres</span><span class="portal-stat-label">Land Gap</span></div>
            </div>
          </div>
        )}

        {/* Industrial areas */}
        {industrialLand.industrialAreas?.map((area: any) => (
          <div class="panel" style="margin-bottom:1rem;">
            <h4 class="detail-block-title" style="margin-bottom:0.75rem;">{area.name} — {area.location}</h4>
            <div class="portal-stats-row" style="margin-bottom:0.75rem;">
              <div class="portal-stat"><span class="portal-stat-value">{fmtNum(area.totalArea)} ac</span><span class="portal-stat-label">Total</span></div>
              <div class="portal-stat"><span class="portal-stat-value">{fmtNum(area.developedArea)} ac</span><span class="portal-stat-label">Developed</span></div>
              <div class="portal-stat"><span class="portal-stat-value">{fmtNum(area.availableForAllotment)} ac</span><span class="portal-stat-label">Available</span></div>
            </div>
            {area.infrastructureStatus && (
              <div class="infra-grid">
                {Object.entries(area.infrastructureStatus).map(([k, v]: [string, any]) => (
                  <div class="infra-item"><span class="infra-label">{k}</span><span class="infra-value">{v}</span></div>
                ))}
              </div>
            )}
          </div>
        ))}

        {/* Infrastructure readiness */}
        {industrialLand.infrastructureReadiness && (
          <div class="panel">
            <h4 class="detail-block-title" style="margin-bottom:0.75rem;">Infrastructure Readiness</h4>
            <div class="infra-ratings">
              {Object.entries(industrialLand.infrastructureReadiness).map(([k, v]: [string, any]) => (
                <div class="infra-rating-item">
                  <div class="infra-rating-header">
                    <span class="infra-rating-name">{k}</span>
                    <span class={`infra-rating-status status-text-${v.status.toLowerCase().replace(/\s/g, '-')}`}>{v.status}</span>
                  </div>
                  <div class="progress-bar-container">
                    <div class="progress-bar" style={`width:${v.rating}%`}></div>
                  </div>
                  {v.gap && <p class="infra-gap">{v.gap}</p>}
                </div>
              ))}
            </div>
          </div>
        )}
      </section>
    </DistrictSection>
  )}

  <!-- Credit & Banking -->
  {creditData && (
    <DistrictSection section="credit">
      <section class="animate-up portal-section">
        <h3 class="section-title">Credit & Banking</h3>
        {creditData.summary && (
          <div class="panel" style="margin-bottom:1.25rem;">
            <div class="portal-stats-row">
              <div class="portal-stat"><span class="portal-stat-value">{fmtRs(creditData.summary.totalCredit)}</span><span class="portal-stat-label">Total Credit</span></div>
              <div class="portal-stat"><span class="portal-stat-value">{fmtRs(creditData.summary.totalDeposits)}</span><span class="portal-stat-label">Total Deposits</span></div>
              <div class="portal-stat"><span class="portal-stat-value">{creditData.summary.creditDepositRatio}%</span><span class="portal-stat-label">CD Ratio</span></div>
              <div class="portal-stat"><span class="portal-stat-value">{creditData.summary.stateAvgCDRatio}%</span><span class="portal-stat-label">State Avg CD Ratio</span></div>
              <div class="portal-stat"><span class="portal-stat-value">{fmtNum(creditData.summary.totalBankBranches)}</span><span class="portal-stat-label">Bank Branches</span></div>
            </div>
          </div>
        )}

        {/* Sector-wise credit */}
        {creditData.sectorWiseCredit && (
          <div class="panel" style="margin-bottom:1rem;">
            <h4 class="detail-block-title" style="margin-bottom:0.75rem;">Sector-wise Credit</h4>
            {Object.entries(creditData.sectorWiseCredit).map(([sector, data]: [string, any]) => (
              <div class="credit-sector">
                <div class="credit-sector-header">
                  <span class="credit-sector-name">{sector}</span>
                  <span class="credit-sector-value">{fmtRs(data.outstanding)} ({data.percentOfTotal}%)</span>
                </div>
                {data.achievement && (
                  <div class="progress-bar-container" style="margin-bottom:0.25rem;">
                    <div class="progress-bar" style={`width:${Math.min(data.achievement, 100)}%`}></div>
                  </div>
                )}
                {data.achievement && <span class="credit-achievement">{data.achievement}% of target achieved</span>}
              </div>
            ))}
          </div>
        )}

        {/* Challenges */}
        {creditData.challenges?.length > 0 && (
          <div class="panel">
            <h4 class="detail-block-title" style="margin-bottom:0.75rem;">Challenges</h4>
            {creditData.challenges.map((c: any) => (
              <div class="credit-challenge">
                <span class="credit-challenge-issue">{c.issue}</span>
                <span class="credit-challenge-gap">Current: {c.current} | Target: {c.target} | Gap: {c.gap}</span>
                <span class="credit-challenge-impact">{c.impact}</span>
              </div>
            ))}
          </div>
        )}
      </section>
    </DistrictSection>
  )}

  <!-- MSME -->
  {msme && (
    <DistrictSection section="msme">
      <section class="animate-up portal-section">
        <h3 class="section-title">MSME Registrations</h3>
        <div class="panel">
          <div class="portal-stats-row" style="margin-bottom:1rem;">
            <div class="portal-stat"><span class="portal-stat-value">{fmtNum(msme.statistics.total)}</span><span class="portal-stat-label">Total MSMEs</span></div>
            <div class="portal-stat"><span class="portal-stat-value">{fmtRs(msme.statistics.totalInvestment)}</span><span class="portal-stat-label">Total Investment</span></div>
            <div class="portal-stat"><span class="portal-stat-value">{fmtNum(msme.statistics.totalEmployment)}</span><span class="portal-stat-label">Employment</span></div>
            {msme.growthTrends?.yearOverYear && <div class="portal-stat"><span class="portal-stat-value">{msme.growthTrends.yearOverYear}</span><span class="portal-stat-label">YoY Growth</span></div>}
          </div>

          {msme.statistics.bySector && (
            <div style="margin-bottom:1rem;">
              <h5 class="detail-block-title">By Sector</h5>
              <div class="msme-breakdown">
                {Object.entries(msme.statistics.bySector).map(([k, v]: [string, any]) => (
                  <div class="msme-bar-item">
                    <span class="msme-bar-label">{k}</span>
                    <div class="msme-bar-track">
                      <div class="msme-bar-fill" style={`width:${(v / msme.statistics.total * 100)}%`}></div>
                    </div>
                    <span class="msme-bar-value">{fmtNum(v)}</span>
                  </div>
                ))}
              </div>
            </div>
          )}

          {msme.statistics.byYear && (
            <div>
              <h5 class="detail-block-title">Registrations by Year</h5>
              <div class="msme-breakdown">
                {Object.entries(msme.statistics.byYear).map(([year, count]: [string, any]) => (
                  <div class="msme-bar-item">
                    <span class="msme-bar-label">{year}</span>
                    <div class="msme-bar-track">
                      <div class="msme-bar-fill" style={`width:${(count / Math.max(...Object.values(msme.statistics.byYear) as number[]) * 100)}%`}></div>
                    </div>
                    <span class="msme-bar-value">{fmtNum(count)}</span>
                  </div>
                ))}
              </div>
            </div>
          )}
        </div>
      </section>
    </DistrictSection>
  )}

  <!-- Investment Proposals -->
  {investments && (
    <DistrictSection section="investments">
      <section class="animate-up portal-section">
        <h3 class="section-title">Investment Proposals</h3>
        {investments.summary && (
          <div class="panel" style="margin-bottom:1.25rem;">
            <div class="portal-stats-row">
              <div class="portal-stat"><span class="portal-stat-value">{investments.summary.totalProposals}</span><span class="portal-stat-label">Total Proposals</span></div>
              <div class="portal-stat"><span class="portal-stat-value">{investments.summary.approvedProposals}</span><span class="portal-stat-label">Approved</span></div>
              <div class="portal-stat"><span class="portal-stat-value">{fmtRs(investments.summary.proposedInvestment)}</span><span class="portal-stat-label">Proposed</span></div>
              <div class="portal-stat"><span class="portal-stat-value">{fmtRs(investments.summary.realizedInvestment)}</span><span class="portal-stat-label">Realized</span></div>
              <div class="portal-stat"><span class="portal-stat-value">{investments.summary.realizationRate}%</span><span class="portal-stat-label">Realization Rate</span></div>
            </div>
          </div>
        )}

        {investments.majorProposals?.length > 0 && (
          <div class="panel" style="padding:0; overflow:hidden; margin-bottom:1rem;">
            <h4 class="comparison-title">Major Proposals</h4>
            <div class="table-scroll">
              <table class="portal-table">
                <thead>
                  <tr>
                    <th>Project</th>
                    <th>Investor</th>
                    <th>Sector</th>
                    <th>Investment</th>
                    <th>Jobs</th>
                    <th>Status</th>
                  </tr>
                </thead>
                <tbody>
                  {investments.majorProposals.map((p: any) => (
                    <tr>
                      <td class="table-name">{p.projectName}</td>
                      <td>{p.investor}</td>
                      <td>{p.sector}</td>
                      <td>{fmtRs(p.investment)}</td>
                      <td>{fmtNum(p.projectedJobs)}</td>
                      <td><span class="status-badge">{p.status}</span></td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
          </div>
        )}

        {investments.bottlenecks?.length > 0 && (
          <div class="panel">
            <h4 class="detail-block-title" style="margin-bottom:0.75rem;">Bottlenecks</h4>
            {investments.bottlenecks.map((b: any) => (
              <div class="bottleneck-item">
                <span class="bottleneck-stage">{b.stage}</span>
                <span class="bottleneck-detail">{b.delayedProposals} proposals delayed, avg {b.avgDelay} days</span>
                <span class="bottleneck-impact">{b.impact}</span>
              </div>
            ))}
          </div>
        )}
      </section>
    </DistrictSection>
  )}

  </div><!-- /tab-data -->

  <!-- Discussion Tab -->
  <div class="portal-tab-content" id="tab-discuss" style="display:none;">
    <Discussion pageSlug={`${stateSlug}/${d.id}`} project="district" />
  </div>

  <!-- Sources Tab -->
  <div class="portal-tab-content" id="tab-sources" style="display:none;">
    {(d as any).dataSources?.length > 0 ? (
      <div id="sources" class="portal-section">
        <h3 class="section-title">Data Sources</h3>
        <p class="sources-summary">{(d as any).dataSources.length} sources {d.dataCompleteness?.lastVerified ? `· Last verified: ${d.dataCompleteness.lastVerified}` : ''}</p>
        <div class="panel" style="padding:0; overflow:hidden;">
          <div class="table-scroll">
            <table class="portal-table">
              <thead><tr><th>Source</th><th>Type</th><th>Fields</th></tr></thead>
              <tbody>
                {(d as any).dataSources.map((src: any) => (
                  <tr>
                    <td>{src.url ? <a href={src.url} target="_blank" rel="noopener" class="source-link">{src.name}</a> : src.name}</td>
                    <td><span class="source-type-badge">{src.type}</span></td>
                    <td class="source-fields-cell">{src.fields?.join(', ')}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        </div>
      </div>
    ) : (
      <div class="portal-section">
        <p style="color:var(--gray-400); text-align:center; padding:2rem;">No data sources documented for this district.</p>
      </div>
    )}
  </div>

</BaseLayout>

<style>
  /* ── Section rhythm ── */
  .portal-section {
    margin: 0; padding: 2.5rem 2rem;
    border: none; position: relative;
  }
  .portal-section + .portal-section { border-top: none; }

  /* Alternating tint — white vs slate wash */
  .portal-section.alt {
    background: #eef2f7;
  }
  .portal-section.alt .panel {
    box-shadow: 0 2px 8px rgba(0,0,0,0.06), 0 0 0 1px rgba(0,0,0,0.03);
  }

  /* Section title accent bar */
  .portal-section .section-title {
    margin-bottom: 1.5rem; padding-left: 0.875rem;
    border-left: 3px solid var(--primary); position: relative;
  }
  .portal-section.alt .section-title { border-left-color: var(--teal); }

  /* Data by Role tab — alternating bands on DistrictSection wrappers */
  #tab-data > div,
  #tab-data > [data-section] {
    padding: 2.5rem 2rem; border: none;
  }
  #tab-data > div:nth-child(even),
  #tab-data > [data-section]:nth-child(even) {
    background: #eef2f7;
  }
  #tab-data > div:nth-child(even) .panel,
  #tab-data > [data-section]:nth-child(even) .panel {
    box-shadow: 0 2px 8px rgba(0,0,0,0.06), 0 0 0 1px rgba(0,0,0,0.03);
  }
  #tab-data > div:nth-child(odd),
  #tab-data > [data-section]:nth-child(odd) {
    background: white;
  }
  #tab-data > div .section-title,
  #tab-data > [data-section] .section-title {
    padding-left: 0.875rem;
    border-left: 3px solid var(--primary);
  }
  #tab-data > div:nth-child(even) .section-title,
  #tab-data > [data-section]:nth-child(even) .section-title {
    border-left-color: var(--teal);
  }

  /* Tab content containers */
  .portal-tab-content { border: none; }
  #tab-today, #tab-data { border-radius: 0 0 12px 12px; overflow: hidden; box-shadow: 0 2px 12px rgba(0,0,0,0.06); }

  /* Role selector */
  .role-selector-desc { font-size: 0.875rem; color: var(--gray-600); margin-bottom: 1.25rem; }
  .role-selector-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 0.75rem; }
  .role-card {
    display: flex; flex-direction: column; gap: 0.375rem;
    padding: 1.25rem; background: white; border: 1px solid var(--gray-200);
    border-radius: var(--radius-lg); cursor: pointer; text-align: left;
    font-family: var(--font-body); transition: all 0.2s;
  }
  .role-card:hover { border-color: var(--primary); box-shadow: var(--shadow-md); transform: translateY(-2px); }
  .role-card-icon { font-size: 1.5rem; }
  .role-card-name { font-size: 0.9375rem; font-weight: 700; color: var(--gray-900); }
  .role-card-desc { font-size: 0.75rem; color: var(--gray-500); line-height: 1.4; flex: 1; }
  .role-card-arrow { font-size: 0.8125rem; font-weight: 700; color: var(--primary); margin-top: 0.5rem; }

  /* Fallback */
  .rd-fallback { text-align: center; padding: 3rem 2rem; color: var(--gray-500); }
  .rd-fallback-icon { font-size: 2rem; display: block; margin-bottom: 0.75rem; }
  .rd-fallback h3 { font-size: 1.125rem; color: var(--gray-700); margin-bottom: 0.5rem; }
  .rd-fallback p { font-size: 0.875rem; }

  /* Today section */
  .portal-sub-title { font-size: 0.75rem; font-weight: 700; color: var(--gray-500); text-transform: uppercase; letter-spacing: 0.06em; margin-bottom: 0.75rem; }
  .today-two-col { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }
  .today-donut-row { display: flex; align-items: center; gap: 1.25rem; }
  .today-donut { position: relative; width: 140px; height: 140px; flex-shrink: 0; }
  .today-donut svg { width: 100%; height: 100%; transform: rotate(-90deg); }
  .today-donut-center { position: absolute; inset: 0; display: flex; flex-direction: column; align-items: center; justify-content: center; }
  .today-donut-val { font-size: 1.125rem; font-weight: 800; color: var(--gray-900); line-height: 1; }
  .today-donut-unit { font-size: 0.5625rem; color: var(--gray-500); text-transform: uppercase; }
  .today-legend { display: flex; flex-direction: column; gap: 0.375rem; font-size: 0.75rem; color: var(--gray-600); }
  .today-dot { display: inline-block; width: 8px; height: 8px; border-radius: 2px; margin-right: 0.375rem; }
  .today-demo { display: flex; flex-direction: column; }
  .today-demo-row { display: flex; justify-content: space-between; padding: 0.5rem 0; border-bottom: 1px solid var(--gray-100); font-size: 0.8125rem; }
  .today-demo-row:last-child { border-bottom: none; }
  .today-demo-row span { color: var(--gray-500); }
  .today-demo-row strong { color: var(--gray-800); }

  .today-live-dot { display: inline-block; width: 6px; height: 6px; border-radius: 50%; background: var(--green); margin-right: 0.375rem; box-shadow: 0 0 0 2px rgba(16,185,129,0.2); }
  .today-live-grid { display: flex; gap: 1.5rem; flex-wrap: wrap; }
  .today-live-item { display: flex; flex-direction: column; gap: 0.0625rem; }
  .today-live-name { font-size: 0.6875rem; color: var(--gray-500); text-transform: capitalize; }
  .today-live-price { font-size: 0.9375rem; font-weight: 800; color: var(--gray-900); }
  .today-live-change { font-size: 0.6875rem; font-weight: 700; }
  .today-live-change.up { color: var(--green); }
  .today-live-change.down { color: var(--red); }
  .today-live-market { font-size: 0.5625rem; color: var(--gray-400); }

  /* Strengths & Challenges */
  .sc-two-col { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }
  .sc-panel { padding: 1.25rem; }
  .sc-header { font-size: 0.75rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.06em; padding-bottom: 0.625rem; margin-bottom: 0.5rem; border-bottom: 2px solid; }
  .sc-green { color: var(--green-dark); border-color: var(--green); }
  .sc-red { color: var(--red-dark); border-color: var(--red); }
  .sc-items { list-style: none; }
  .sc-items li { font-size: 0.8125rem; color: var(--gray-700); padding: 0.3125rem 0; display: flex; align-items: flex-start; gap: 0.375rem; line-height: 1.4; }
  .sc-mark { flex-shrink: 0; font-weight: 700; font-size: 0.6875rem; margin-top: 0.125rem; }
  .sc-check { color: var(--green); }
  .sc-cross { color: var(--red); }
  .community-pill {
    display: inline-block; font-size: 0.5rem; font-weight: 700; text-transform: uppercase;
    letter-spacing: 0.04em; color: var(--green-dark); background: var(--green-light);
    padding: 0.0625rem 0.3125rem; border-radius: 2px; margin-left: 0.25rem;
    vertical-align: middle; white-space: nowrap;
  }

  /* Opportunities */
  .opp-items { list-style: none; }
  .opp-items li { font-size: 0.8125rem; color: var(--gray-700); padding: 0.375rem 0; display: flex; align-items: flex-start; gap: 0.375rem; line-height: 1.4; border-bottom: 1px solid var(--gray-100); }
  .opp-items li:last-child { border-bottom: none; }
  .opp-bolt { color: var(--yellow); flex-shrink: 0; }

  /* Goals */
  .goals-row { display: flex; gap: 1rem; flex-wrap: wrap; }
  .goal-card { flex: 1; min-width: 120px; text-align: center; padding: 1.25rem 1rem; }
  .goal-from { font-size: 1rem; font-weight: 700; color: var(--gray-400); }
  .goal-arrow { font-size: 1rem; color: var(--gray-300); margin: 0.25rem 0; }
  .goal-to { font-size: 1.25rem; font-weight: 800; color: var(--primary); }
  .goal-label { font-size: 0.625rem; font-weight: 700; color: var(--gray-500); text-transform: uppercase; letter-spacing: 0.04em; margin-top: 0.5rem; }

  /* Next Steps */
  .nextstep-item { margin-bottom: 1rem; }
  .nextstep-item:last-child { margin-bottom: 0; }
  .nextstep-header { display: flex; justify-content: space-between; margin-bottom: 0.375rem; }
  .nextstep-name { font-size: 0.875rem; font-weight: 700; color: var(--gray-800); }
  .nextstep-pct { font-size: 0.75rem; font-weight: 700; color: var(--gray-500); }
  .nextstep-bar { height: 6px; background: var(--gray-100); border-radius: 3px; overflow: hidden; }
  .nextstep-fill { height: 100%; border-radius: 3px; background: linear-gradient(90deg, var(--primary), var(--teal)); }
  .nextstep-tasks { list-style: none; margin-top: 0.375rem; }
  .nextstep-tasks li { font-size: 0.75rem; color: var(--gray-500); padding: 0.125rem 0 0.125rem 0.75rem; position: relative; }
  .nextstep-tasks li::before { content: '\00B7'; position: absolute; left: 0; color: var(--gray-400); }

  /* Tabs */
  .portal-tabs {
    display: flex; gap: 0; margin-bottom: 0;
    background: white; border-bottom: 2px solid var(--gray-200);
    border-radius: 12px 12px 0 0; padding: 0 0.5rem;
  }
  .portal-tab {
    padding: 1rem 1.5rem; border: none; background: none;
    cursor: pointer; font-family: var(--font-body); font-size: 0.9375rem;
    font-weight: 600; color: var(--gray-400); border-bottom: 3px solid transparent;
    margin-bottom: -2px; transition: color 0.15s;
  }
  .portal-tab:hover { color: var(--gray-700); }
  .portal-tab.active { color: var(--gray-900); border-bottom-color: var(--gray-900); }
  .portal-tab-content { }
  .portal-tab-content[style*="display: none"] { display: none; }

  /* Shared stats row */
  .portal-stats-row { display: flex; gap: 2rem; flex-wrap: wrap; }
  .portal-stat { display: flex; flex-direction: column; }
  .portal-stat-value { font-size: 1.25rem; font-weight: 800; color: var(--gray-900); }
  .portal-stat-label { font-size: 0.6875rem; color: var(--gray-500); text-transform: uppercase; letter-spacing: 0.04em; }

  /* Shared table */
  .table-scroll { overflow-x: auto; }
  .portal-table { width: 100%; border-collapse: collapse; min-width: 600px; }
  .portal-table th {
    padding: 0.625rem 1rem; text-align: left; font-size: 0.6875rem;
    font-weight: 600; text-transform: uppercase; letter-spacing: 0.06em;
    color: var(--gray-500); background: var(--gray-50); border-bottom: 1px solid var(--gray-200);
  }
  .portal-table td {
    padding: 0.5rem 1rem; font-size: 0.8125rem;
    border-bottom: 1px solid var(--gray-100); color: var(--gray-700); vertical-align: top;
  }
  .portal-table tr:last-child td { border-bottom: none; }
  .portal-table tr:hover { background: var(--gray-50); }
  .table-name { font-weight: 600; color: var(--gray-800); }
  .comparison-title {
    padding: 0.75rem 1rem; font-size: 0.875rem; font-weight: 700;
    color: var(--gray-800); background: var(--gray-50); border-bottom: 1px solid var(--gray-200);
  }

  /* Sector detail cards */
  .sector-detail-card { margin-bottom: 1.25rem; border-top: 3px solid var(--teal); }
  .sector-detail-header { display: flex; justify-content: space-between; align-items: flex-start; gap: 1rem; margin-bottom: 1rem; }
  .sector-detail-name { font-size: 1.125rem; font-weight: 700; color: var(--gray-900); }
  .sector-detail-note { font-size: 0.75rem; color: var(--gray-500); margin-top: 0.25rem; }
  .priority-badge {
    font-size: 0.625rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.06em;
    padding: 0.25rem 0.625rem; border-radius: 4px; white-space: nowrap;
  }
  .priority-highest { color: #065f46; background: var(--green-light); }
  .priority-high { color: #92400e; background: var(--yellow-light); }
  .priority-mediumhigh, .priority-medium { color: var(--primary-dark); background: var(--primary-light); }

  .sector-detail-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 1rem; margin-bottom: 1rem; }
  .detail-block { padding: 0.75rem; background: var(--gray-50); border-radius: 6px; }
  .detail-block-title { font-size: 0.75rem; font-weight: 700; color: var(--gray-600); text-transform: uppercase; letter-spacing: 0.04em; margin-bottom: 0.375rem; }
  .detail-value-large { font-size: 1.125rem; font-weight: 800; color: var(--gray-900); margin-bottom: 0.5rem; }
  .detail-breakdown { display: flex; flex-direction: column; gap: 0.125rem; }
  .detail-sub-title { font-size: 0.625rem; font-weight: 700; color: var(--gray-500); text-transform: uppercase; letter-spacing: 0.04em; }
  .detail-row { display: flex; justify-content: space-between; gap: 0.5rem; font-size: 0.75rem; }
  .detail-row-label { color: var(--gray-500); }
  .detail-row-value { color: var(--gray-800); font-weight: 600; }
  .timeline-row { flex-direction: column; }
  .timeline-row .detail-row-value { font-weight: 500; color: var(--gray-600); }

  .detail-section { margin-bottom: 0.75rem; }
  .detail-chips { display: flex; flex-wrap: wrap; gap: 0.375rem; }
  .detail-chip {
    font-size: 0.75rem; padding: 0.25rem 0.625rem;
    background: var(--gray-50); border: 1px solid var(--gray-200);
    border-radius: 4px; color: var(--gray-700);
  }

  .buyers-grid { display: flex; flex-direction: column; gap: 0.375rem; }
  .buyer-group { display: flex; gap: 0.5rem; font-size: 0.75rem; }
  .buyer-category { font-weight: 700; color: var(--gray-600); text-transform: capitalize; min-width: 80px; }
  .buyer-list { color: var(--gray-700); }

  .risks-list { display: flex; flex-direction: column; gap: 0.5rem; }
  .risk-item { display: flex; gap: 0.75rem; align-items: flex-start; }
  .risk-severity {
    font-size: 0.5625rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.04em;
    padding: 0.125rem 0.375rem; border-radius: 3px; white-space: nowrap; flex-shrink: 0; margin-top: 0.125rem;
  }
  .severity-critical { color: #991b1b; background: var(--red-light); }
  .severity-high { color: #92400e; background: var(--yellow-light); }
  .severity-medium { color: var(--primary-dark); background: var(--primary-light); }
  .severity-low { color: #065f46; background: var(--green-light); }
  .risk-content { display: flex; flex-direction: column; }
  .risk-text { font-size: 0.8125rem; font-weight: 600; color: var(--gray-800); }
  .risk-mitigation { font-size: 0.75rem; color: var(--gray-500); }

  .sector-detail-footer { display: flex; gap: 1rem; flex-wrap: wrap; margin-top: 0.75rem; padding-top: 0.75rem; border-top: 1px solid var(--gray-100); }
  .sector-confidence { font-size: 0.8125rem; font-weight: 700; color: var(--teal); }
  .sector-location { font-size: 0.8125rem; color: var(--gray-500); }
  .sector-recommendation { font-size: 0.8125rem; font-weight: 600; color: var(--green-dark); margin-top: 0.375rem; }

  /* Status badges */
  .status-badge {
    font-size: 0.625rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.04em;
    padding: 0.125rem 0.5rem; border-radius: 3px; white-space: nowrap;
    color: var(--teal); background: rgba(13,148,136,0.08);
  }
  .status-active { color: #065f46; background: var(--green-light); }
  .status-under-formation { color: #92400e; background: var(--yellow-light); }

  /* Infrastructure */
  .infra-grid { display: flex; flex-direction: column; gap: 0.375rem; }
  .infra-item { display: flex; gap: 0.5rem; font-size: 0.75rem; padding: 0.375rem 0; border-bottom: 1px solid var(--gray-100); }
  .infra-item:last-child { border-bottom: none; }
  .infra-label { font-weight: 700; color: var(--gray-600); text-transform: capitalize; min-width: 70px; }
  .infra-value { color: var(--gray-700); }

  .infra-ratings { display: flex; flex-direction: column; gap: 1rem; }
  .infra-rating-item { }
  .infra-rating-header { display: flex; justify-content: space-between; margin-bottom: 0.25rem; }
  .infra-rating-name { font-size: 0.8125rem; font-weight: 600; color: var(--gray-700); text-transform: capitalize; }
  .status-text-good { color: var(--green); }
  .status-text-moderate { color: var(--yellow); }
  .status-text-critical-gap { color: var(--red); }
  .infra-gap { font-size: 0.6875rem; color: var(--gray-500); margin-top: 0.25rem; }

  .progress-bar-container { height: 6px; background: var(--gray-100); border-radius: 3px; overflow: hidden; }
  .progress-bar { height: 100%; border-radius: 3px; background: linear-gradient(90deg, var(--primary), var(--teal)); }

  /* Credit */
  .credit-sector { margin-bottom: 0.875rem; }
  .credit-sector-header { display: flex; justify-content: space-between; margin-bottom: 0.25rem; }
  .credit-sector-name { font-size: 0.8125rem; font-weight: 700; color: var(--gray-700); text-transform: capitalize; }
  .credit-sector-value { font-size: 0.8125rem; font-weight: 600; color: var(--gray-800); }
  .credit-achievement { font-size: 0.6875rem; color: var(--gray-500); }

  .credit-challenge { display: flex; flex-direction: column; gap: 0.125rem; padding: 0.5rem 0; border-bottom: 1px solid var(--gray-100); }
  .credit-challenge:last-child { border-bottom: none; }
  .credit-challenge-issue { font-size: 0.8125rem; font-weight: 700; color: var(--gray-800); }
  .credit-challenge-gap { font-size: 0.75rem; color: var(--gray-600); }
  .credit-challenge-impact { font-size: 0.75rem; color: var(--red); font-weight: 500; }

  /* MSME bars */
  .msme-breakdown { display: flex; flex-direction: column; gap: 0.5rem; }
  .msme-bar-item { display: flex; align-items: center; gap: 0.75rem; }
  .msme-bar-label { font-size: 0.75rem; font-weight: 600; color: var(--gray-600); min-width: 100px; text-transform: capitalize; }
  .msme-bar-track { flex: 1; height: 6px; background: var(--gray-100); border-radius: 3px; overflow: hidden; }
  .msme-bar-fill { height: 100%; border-radius: 3px; background: var(--primary); }
  .msme-bar-value { font-size: 0.75rem; font-weight: 700; color: var(--gray-800); min-width: 40px; text-align: right; }

  /* Investment bottlenecks */
  .bottleneck-item { display: flex; flex-direction: column; gap: 0.125rem; padding: 0.5rem 0; border-bottom: 1px solid var(--gray-100); }
  .bottleneck-item:last-child { border-bottom: none; }
  .bottleneck-stage { font-size: 0.8125rem; font-weight: 700; color: var(--gray-800); }
  .bottleneck-detail { font-size: 0.75rem; color: var(--gray-600); }
  .bottleneck-impact { font-size: 0.75rem; color: var(--red); font-weight: 500; }

  /* Live data */
  .live-badge {
    font-size: 0.625rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.04em;
    color: var(--orange); background: var(--orange-light);
    padding: 0.125rem 0.5rem; border-radius: 3px; vertical-align: middle; margin-left: 0.5rem;
  }
  .live-data-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }

  .commodity-item { padding: 0.625rem 0; border-bottom: 1px solid var(--gray-100); }
  .commodity-item:last-child { border-bottom: none; }
  .commodity-header { display: flex; justify-content: space-between; }
  .commodity-name { font-size: 0.8125rem; font-weight: 600; color: var(--gray-800); text-transform: capitalize; }
  .commodity-price { font-size: 0.9375rem; font-weight: 800; color: var(--gray-900); }
  .commodity-meta { display: flex; justify-content: space-between; margin-top: 0.125rem; }
  .commodity-market { font-size: 0.6875rem; color: var(--gray-500); }
  .commodity-change { font-size: 0.6875rem; font-weight: 700; }
  .commodity-change.positive { color: var(--green); }
  .commodity-change.negative { color: var(--red); }

  .rainfall-grid { display: flex; flex-direction: column; gap: 0.5rem; }
  .rainfall-item { display: flex; align-items: center; gap: 0.75rem; padding: 0.375rem 0; border-bottom: 1px solid var(--gray-100); }
  .rainfall-item:last-child { border-bottom: none; }
  .rainfall-label { font-size: 0.75rem; color: var(--gray-500); min-width: 80px; }
  .rainfall-value { font-size: 0.8125rem; font-weight: 700; color: var(--gray-800); }
  .rainfall-deviation { font-size: 0.6875rem; font-weight: 700; }
  .rainfall-deviation.positive { color: var(--green); }
  .rainfall-deviation.negative { color: var(--red); }
  .rainfall-status { font-size: 0.625rem; font-weight: 700; text-transform: uppercase; padding: 0.125rem 0.375rem; border-radius: 3px; }
  .rainfall-status.status-deficient { color: #92400e; background: var(--yellow-light); }
  .rainfall-status.status-normal { color: #065f46; background: var(--green-light); }
  .rainfall-status.status-excess { color: var(--primary-dark); background: var(--primary-light); }

  /* Source table */
  .source-link { color: var(--primary); text-decoration: none; font-weight: 500; }
  .source-link:hover { text-decoration: underline; }
  .source-type-badge {
    font-size: 0.625rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.04em;
    color: var(--teal); background: rgba(13,148,136,0.08);
    padding: 0.125rem 0.5rem; border-radius: 3px; white-space: nowrap;
  }
  .source-fields-cell { font-size: 0.75rem; color: var(--gray-500); }
  .sources-summary { font-size: 0.8125rem; color: var(--gray-500); margin-bottom: 1rem; }

  /* KDEM */
  .kdem-header { display: flex; justify-content: space-between; align-items: flex-start; gap: 1rem; flex-wrap: wrap; }
  .kdem-cluster-name { font-size: 1.125rem; font-weight: 700; color: var(--gray-900); }
  .kdem-brand { font-size: 0.8125rem; color: var(--gray-500); margin-top: 0.125rem; }
  .kdem-tier {
    font-size: 0.625rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.06em;
    padding: 0.25rem 0.75rem; border-radius: 4px; white-space: nowrap;
  }
  .tier-1 { color: #065f46; background: var(--green-light); }
  .tier-2 { color: var(--primary-dark); background: var(--primary-light); }
  .tier-3 { color: #92400e; background: var(--yellow-light); }

  .kdem-two-col { display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem; }
  .kdem-tags { display: flex; flex-wrap: wrap; gap: 0.375rem; margin-top: 0.375rem; }
  .kdem-tag {
    font-size: 0.75rem; font-weight: 600; padding: 0.25rem 0.625rem;
    background: var(--primary-light); color: var(--primary-dark);
    border-radius: 4px;
  }
  .kdem-anchor { display: flex; justify-content: space-between; align-items: center; padding: 0.375rem 0; border-bottom: 1px solid var(--gray-100); }
  .kdem-anchor:last-child { border-bottom: none; }
  .kdem-anchor-name { font-size: 0.8125rem; font-weight: 600; color: var(--gray-800); }
  .kdem-anchor-status {
    font-size: 0.625rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.04em;
    padding: 0.125rem 0.5rem; border-radius: 3px;
  }
  .status-operational { color: #065f46; background: var(--green-light); }
  .status-planned { color: #92400e; background: var(--yellow-light); }

  .kdem-proximity-list { list-style: none; }
  .kdem-proximity-list li {
    font-size: 0.8125rem; color: var(--gray-700); padding: 0.375rem 0;
    border-bottom: 1px solid var(--gray-100); padding-left: 1rem; position: relative;
  }
  .kdem-proximity-list li:last-child { border-bottom: none; }
  .kdem-proximity-list li::before { content: '\2022'; position: absolute; left: 0; color: var(--primary); }

  .kdem-policy { display: flex; flex-direction: column; gap: 0.0625rem; padding: 0.5rem 0; border-bottom: 1px solid var(--gray-100); }
  .kdem-policy:last-child { border-bottom: none; }
  .kdem-policy-name { font-size: 0.8125rem; font-weight: 700; color: var(--gray-800); }
  .kdem-policy-relevance { font-size: 0.75rem; color: var(--gray-500); }

  .kdem-dashboard-link {
    display: inline-block; font-size: 0.8125rem; font-weight: 600;
    color: var(--primary); text-decoration: none;
  }
  .kdem-dashboard-link:hover { text-decoration: underline; }

  @media (max-width: 1024px) {
    .sector-detail-grid { grid-template-columns: repeat(2, 1fr); }
    .live-data-grid { grid-template-columns: 1fr; }
    .today-two-col { grid-template-columns: 1fr; }
    .sc-two-col { grid-template-columns: 1fr; }
  }
  @media (max-width: 768px) {
    .portal-title { font-size: 1.375rem; }
    .sector-detail-grid { grid-template-columns: 1fr; }
    .portal-stats-row { gap: 1rem; }
    .portal-tabs { gap: 0; }
    .portal-tab { padding: 0.5rem 0.75rem; font-size: 0.75rem; flex: 1; text-align: center; }
    .portal-section { padding: 1.75rem 1.25rem; }
    #tab-data > div, #tab-data > [data-section] { padding: 1.75rem 1.25rem; }
    .goals-row { flex-direction: column; }
    .goal-card { min-width: auto; }
    .today-donut-row { flex-direction: column; align-items: flex-start; }
    .kdem-header { flex-direction: column; }
    .kdem-two-col { grid-template-columns: 1fr; }
    .opp-sectors { flex-direction: column; }
    .opp-card { min-width: auto; }
    .live-data-grid { grid-template-columns: 1fr; }
    .infra-label { min-width: 60px; }
    .msme-bar-label { min-width: 70px; }
    .buyer-category { min-width: 60px; }
    .portal-hero { margin-bottom: 0.75rem; }
    .role-selector-grid { grid-template-columns: repeat(2, 1fr); }
  }
</style>

<script is:inline>
  document.addEventListener('DOMContentLoaded', () => {
    const tabs = document.querySelectorAll('.portal-tab');
    const todayTab = document.getElementById('tab-today');
    const dataTab = document.getElementById('tab-data');
    const discussTab = document.getElementById('tab-discuss');
    const sourcesTab = document.getElementById('tab-sources');
    if (!tabs.length || !todayTab || !dataTab || !discussTab) return;

    const allPanels = { today: todayTab, data: dataTab, discuss: discussTab, sources: sourcesTab };

    // Role dashboard elements
    const roleSelector = document.getElementById('role-no-selection');
    const roleDashboards = document.querySelectorAll('[data-role-dashboard]');
    const roleSelect = document.getElementById('role-select');

    function switchTab(tabName) {
      if (!allPanels[tabName]) tabName = 'today';
      tabs.forEach(t => t.classList.toggle('active', t.dataset.tab === tabName));
      Object.entries(allPanels).forEach(([name, el]) => {
        if (el) el.style.display = name === tabName ? '' : 'none';
      });
      if (window.location.hash) {
        const target = document.querySelector(window.location.hash);
        if (target) setTimeout(() => target.scrollIntoView({ behavior: 'smooth', block: 'start' }), 100);
      }
    }

    function switchRole(roleId) {
      // Show/hide role selector vs dashboard
      if (roleSelector) {
        roleSelector.style.display = (!roleId || roleId === 'full') ? '' : 'none';
      }
      roleDashboards.forEach(el => {
        el.style.display = el.getAttribute('data-role-dashboard') === roleId ? '' : 'none';
      });
      // Update role select dropdown if exists
      if (roleSelect) roleSelect.value = roleId || 'full';

      // Also apply the existing section/roadmap filtering from RoleSwitcher
      const rolesDataEl = document.getElementById('roles-data');
      if (rolesDataEl) {
        try {
          const roles = JSON.parse(rolesDataEl.textContent || '[]');
          const roleMap = {};
          roles.forEach(r => { roleMap[r.id] = r; });
          const role = roleMap[roleId];
          if (role) {
            // Toggle sections
            document.querySelectorAll('[data-section]').forEach(sec => {
              const sn = sec.getAttribute('data-section');
              if (roleId === 'full' || role.sections.includes(sn)) {
                sec.style.display = '';
              } else {
                sec.style.display = 'none';
              }
            });
            // Toggle roadmap components
            document.querySelectorAll('.roadmap-component').forEach(comp => {
              const owner = comp.getAttribute('data-owner');
              if (roleId === 'full' || roleId === 'dc' || !role.roadmapOwners || role.roadmapOwners.length === 0) {
                comp.style.display = '';
              } else if (owner && role.roadmapOwners.includes(owner)) {
                comp.style.display = '';
              } else {
                comp.style.display = 'none';
              }
            });
          }
        } catch(e) {}
      }

      // Update URL
      const url = new URL(window.location);
      if (roleId && roleId !== 'full') {
        url.searchParams.set('role', roleId);
      } else {
        url.searchParams.delete('role');
      }
      window.history.pushState({}, '', url);
    }

    // Role card clicks
    document.querySelectorAll('[data-select-role]').forEach(card => {
      card.addEventListener('click', () => {
        const roleId = card.getAttribute('data-select-role');
        switchRole(roleId);
      });
    });

    // Role select dropdown change (from RoleSwitcher)
    if (roleSelect) {
      roleSelect.addEventListener('change', () => {
        switchRole(roleSelect.value);
      });
    }

    // Read URL params on load
    const params = new URLSearchParams(window.location.search);
    const urlTab = params.get('tab');
    const urlRole = params.get('role');

    if (urlTab && allPanels[urlTab]) {
      switchTab(urlTab);
    }
    if (urlRole) {
      switchRole(urlRole);
      if (!urlTab) switchTab('data'); // Auto-switch to Dashboard tab when role in URL
    }

    // Tab click
    tabs.forEach(tab => {
      tab.addEventListener('click', () => {
        const tabName = tab.dataset.tab;
        switchTab(tabName);
        const url = new URL(window.location);
        if (tabName === 'today') {
          url.searchParams.delete('tab');
        } else {
          url.searchParams.set('tab', tabName);
        }
        url.hash = '';
        window.history.pushState({}, '', url);
      });
    });

    // Browser back/forward
    window.addEventListener('popstate', () => {
      const p = new URLSearchParams(window.location.search);
      switchTab(p.get('tab') || 'today');
      const r = p.get('role');
      if (r) switchRole(r);
    });

    // Hash-based navigation
    if (window.location.hash) {
      const hash = window.location.hash.slice(1);
      const todaySections = ['today', 'strengths', 'opportunities', 'goals', 'nextsteps', 'livedata'];
      const dataSections = ['roadmap', 'industries', 'kdem'];
      if (hash === 'sources') switchTab('sources');
      else if (dataSections.includes(hash)) switchTab('data');
      else if (todaySections.includes(hash)) switchTab('today');
    }
  });
</script>
