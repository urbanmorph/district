---
interface Props {
  title: string;
  description?: string;
  districtCount?: number;
}

const { title, description = 'Development status across India\'s districts', districtCount } = Astro.props;
const base = import.meta.env.BASE_URL;
---

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{title} — India District Development Dashboard</title>
    <meta name="description" content={description}>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Source+Serif+4:wght@600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://unpkg.com/maplibre-gl@4.7.1/dist/maplibre-gl.css">
    <script is:inline src="https://unpkg.com/maplibre-gl@4.7.1/dist/maplibre-gl.js"></script>
</head>
<body>
    <header class="header">
        <div class="container">
            <div class="header-content">
                <div class="header-left">
                    <a href="/" class="header-home">
                        <span class="header-flag" aria-hidden="true">&#x1F1EE;&#x1F1F3;</span>
                        <div>
                            <h1 class="header-title">India District Development Dashboard</h1>
                            <p class="header-subtitle">Development status across {districtCount || 640} districts</p>
                        </div>
                    </a>
                </div>
                <div class="search-box">
                    <svg width="14" height="14" fill="none" stroke="white" stroke-width="2" viewBox="0 0 24 24"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
                    <input type="text" placeholder="Search districts..." id="global-search">
                </div>
            </div>
        </div>
    </header>

    <main>
        <div class="container">
            <slot />
        </div>
    </main>

    <footer class="footer">
        <div class="container">
            <div class="footer-content">
                <div class="footer-links">
                    <a href="/">Home</a>
                    <a href="#">Data Sources</a>
                    <a href="#">Methodology</a>
                    <a href="https://github.com/urbanmorph/district">GitHub</a>
                </div>
                <span class="footer-copy">Data: Census 2011, MoSPI, State DES &middot; urbanmorph.com</span>
            </div>
        </div>
    </footer>
</body>
</html>

<style is:global>
    @import '../styles/global.css';

    /* Header */
    .header {
        background: linear-gradient(to right, #c45e00 0%, #1a2f6d 35%, #1e40af 65%, #0f5132 100%);
        color: white;
        padding: 1.5rem 0;
        position: relative;
        overflow: hidden;
    }
    .header::before {
        content: '';
        position: absolute;
        inset: 0;
        background: url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23ffffff' fill-opacity='0.03'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E");
        pointer-events: none;
    }
    .header-content {
        display: flex;
        justify-content: space-between;
        align-items: center;
        position: relative;
    }
    .header-home {
        display: flex;
        align-items: center;
        gap: 1rem;
        text-decoration: none;
        color: white;
    }
    .header-flag { font-size: 1.5rem; line-height: 1; }
    .header-title {
        font-family: var(--font-display);
        font-size: 1.25rem;
        font-weight: 700;
        color: white;
    }
    .header-subtitle {
        font-size: 0.8125rem;
        color: rgba(255,255,255,0.7);
    }
    .search-box {
        display: flex;
        align-items: center;
        background: rgba(255,255,255,0.12);
        border: 1px solid rgba(255,255,255,0.2);
        border-radius: var(--radius);
        padding: 0.4375rem 0.75rem;
        gap: 0.5rem;
        min-width: 240px;
    }
    .search-box:focus-within { background: rgba(255,255,255,0.2); border-color: rgba(255,255,255,0.4); }
    .search-box svg { opacity: 0.6; flex-shrink: 0; }
    .search-box input {
        background: none; border: none; color: white;
        font-family: var(--font-body); font-size: 0.8125rem;
        width: 100%; outline: none;
    }
    .search-box input::placeholder { color: rgba(255,255,255,0.5); }

    /* Footer */
    .footer {
        background: var(--gray-800);
        color: var(--gray-400);
        padding: 2rem 0;
        margin-top: 2rem;
    }
    .footer-content {
        display: flex;
        justify-content: space-between;
        align-items: center;
    }
    .footer-links { display: flex; gap: 1.5rem; }
    .footer-links a {
        color: var(--gray-400);
        font-size: 0.8125rem;
        text-decoration: none;
    }
    .footer-links a:hover { color: white; }
    .footer-copy { font-size: 0.75rem; color: var(--gray-500); }

    /* Breadcrumb */
    .breadcrumb {
        padding: 0.875rem 0;
        font-size: 0.8125rem;
        color: var(--gray-500);
    }
    .breadcrumb a { color: var(--primary); text-decoration: none; }
    .breadcrumb a:hover { text-decoration: underline; }
    .breadcrumb .sep { margin: 0 0.375rem; color: var(--gray-300); }

    @media (max-width: 768px) {
        .header-content { flex-direction: column; gap: 0.75rem; }
        .search-box { min-width: 100%; }
        .footer-content { flex-direction: column; gap: 1rem; text-align: center; }
    }
</style>
