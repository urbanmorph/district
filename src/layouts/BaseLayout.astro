---
import { getStates } from '../lib/data-loader';

interface Props {
  title: string;
  description?: string;
  districtCount?: number;
  headerTitle?: string;
  breadcrumb?: { label: string; href?: string }[];
}

const { title, description = 'Development status across India\'s districts', districtCount, headerTitle, breadcrumb } = Astro.props;
const base = import.meta.env.BASE_URL;

// Build search index for autocomplete
const states = getStates();
const searchIndex = [
  // States
  ...states.map(s => ({
    name: s.name,
    state: '',
    type: 'state',
    url: `/state/${s.slug}`
  })),
  // Districts
  ...states.flatMap(s =>
    s.districts.map(d => ({
      name: d.name,
      state: s.name,
      type: 'district',
      url: `/district/${s.slug}/${d.id}`
    }))
  )
];
---

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{title} — India District Development Dashboard</title>
    <meta name="description" content={description}>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Source+Serif+4:wght@600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://unpkg.com/maplibre-gl@4.7.1/dist/maplibre-gl.css">
    <script is:inline src="https://unpkg.com/maplibre-gl@4.7.1/dist/maplibre-gl.js"></script>
</head>
<body>
    <header class="header">
        <div class="container">
            <div class="header-content">
                <div class="header-left">
                    <slot name="header-icon">
                        <span class="header-flag" aria-hidden="true">&#x1F1EE;&#x1F1F3;</span>
                    </slot>
                    <div>
                        <a href="/" class="header-home">
                            <h1 class="header-title">{headerTitle || 'India District Development Dashboard'}</h1>
                        </a>
                        {breadcrumb && breadcrumb.length > 0 ? (
                            <nav class="header-breadcrumb">
                                {breadcrumb.map((item, i) => (
                                    <Fragment>
                                        {i > 0 && <span class="hb-sep">&rsaquo;</span>}
                                        {item.href
                                            ? <a href={item.href} class="hb-link">{item.label}</a>
                                            : <span class="hb-current">{item.label}</span>
                                        }
                                    </Fragment>
                                ))}
                            </nav>
                        ) : (
                            <p class="header-subtitle">Development status across {districtCount || 640} districts</p>
                        )}
                    </div>
                </div>
                <div class="search-wrapper">
                    <div class="search-box">
                        <svg width="14" height="14" fill="none" stroke="white" stroke-width="2" viewBox="0 0 24 24"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
                        <input type="text" placeholder="Search for a district or state..." id="global-search" autocomplete="off">
                    </div>
                    <div class="search-dropdown" id="search-dropdown"></div>
                </div>
                <script type="application/json" id="search-index" set:html={JSON.stringify(searchIndex)} />
            </div>
        </div>
    </header>

    <main>
        <div class="container">
            <slot />
        </div>
    </main>

    <footer class="footer">
        <div class="container">
            <div class="footer-content">
                <div class="footer-links">
                    <a href="/">Home</a>
                    <a href="#">Data Sources</a>
                    <a href="#">Methodology</a>
                    <a href="https://github.com/urbanmorph/district">GitHub</a>
                </div>
                <span class="footer-copy">Data: Census 2011, MoSPI, State DES &middot; urbanmorph.com</span>
            </div>
        </div>
    </footer>
</body>
</html>

<style is:global>
    @import '../styles/global.css';

    /* Header */
    .header {
        background: linear-gradient(to right, #c45e00 0%, #1a2f6d 35%, #1e40af 65%, #0f5132 100%);
        color: white;
        padding: 1.5rem 0;
        position: relative;
        z-index: 50;
    }
    .header::before {
        content: '';
        position: absolute;
        inset: 0;
        overflow: hidden;
        background: url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23ffffff' fill-opacity='0.03'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E");
        pointer-events: none;
    }
    .header-content {
        display: flex;
        justify-content: space-between;
        align-items: center;
        position: relative;
    }
    .header-left {
        display: flex;
        align-items: center;
        gap: 0.75rem;
    }
    .header-home {
        text-decoration: none;
        color: white;
    }
    .header-flag { font-size: 1.5rem; line-height: 1; }
    .header-title {
        font-family: var(--font-display);
        font-size: 1.375rem;
        font-weight: 700;
        color: white;
        letter-spacing: -0.01em;
    }
    .header-subtitle {
        font-size: 0.8125rem;
        color: rgba(255,255,255,0.7);
    }
    .header-breadcrumb {
        font-size: 0.875rem; color: rgba(255,255,255,0.7);
        display: flex; align-items: center; gap: 0.375rem; margin-top: 0.25rem;
    }
    .hb-sep { color: rgba(255,255,255,0.4); }
    .hb-link { color: rgba(255,255,255,0.8); text-decoration: none; }
    .hb-link:hover { color: white; }
    .hb-current { color: white; font-weight: 600; }
    .search-wrapper { position: relative; }
    .search-box {
        display: flex;
        align-items: center;
        background: rgba(255,255,255,0.12);
        border: 1px solid rgba(255,255,255,0.2);
        border-radius: var(--radius);
        padding: 0.4375rem 0.75rem;
        gap: 0.5rem;
        min-width: 260px;
    }
    .search-box:focus-within { background: rgba(255,255,255,0.2); border-color: rgba(255,255,255,0.4); }
    .search-box svg { opacity: 0.6; flex-shrink: 0; }
    .search-box input {
        background: none; border: none; color: white;
        font-family: var(--font-body); font-size: 0.8125rem;
        width: 100%; outline: none;
    }
    .search-box input::placeholder { color: rgba(255,255,255,0.5); }

    /* Search dropdown */
    .search-dropdown {
        display: none; position: absolute; top: 100%; left: 0; right: 0;
        margin-top: 0.25rem; background: white; border-radius: var(--radius);
        box-shadow: var(--shadow-xl); border: 1px solid var(--gray-200);
        max-height: 320px; overflow-y: auto; z-index: 100;
    }
    .search-dropdown.open { display: block; }
    .search-result {
        display: flex; flex-direction: column; padding: 0.625rem 0.875rem;
        text-decoration: none; border-bottom: 1px solid var(--gray-100);
        transition: background 0.1s;
    }
    .search-result:last-child { border-bottom: none; }
    .search-result:hover, .search-result.active { background: var(--primary-light); }
    .search-result-name { font-size: 0.875rem; font-weight: 600; color: var(--gray-800); }
    .search-result-state { font-size: 0.6875rem; color: var(--gray-500); }
    .search-result mark { background: var(--yellow-light); color: var(--gray-900); border-radius: 2px; padding: 0 1px; }
    .search-no-results { padding: 0.875rem; font-size: 0.8125rem; color: var(--gray-400); text-align: center; }

    /* Footer */
    .footer {
        background: var(--gray-800);
        color: var(--gray-400);
        padding: 2rem 0;
        margin-top: 2rem;
    }
    .footer-content {
        display: flex;
        justify-content: space-between;
        align-items: center;
    }
    .footer-links { display: flex; gap: 1.5rem; }
    .footer-links a {
        color: var(--gray-400);
        font-size: 0.8125rem;
        text-decoration: none;
    }
    .footer-links a:hover { color: white; }
    .footer-copy { font-size: 0.75rem; color: var(--gray-500); }

    /* Breadcrumb */
    .breadcrumb {
        padding: 0.875rem 0;
        font-size: 0.8125rem;
        color: var(--gray-500);
    }
    .breadcrumb a { color: var(--primary); text-decoration: none; }
    .breadcrumb a:hover { text-decoration: underline; }
    .breadcrumb .sep { margin: 0 0.375rem; color: var(--gray-300); }

    @media (max-width: 768px) {
        .header-content { flex-direction: column; gap: 0.75rem; }
        .search-wrapper { width: 100%; }
        .search-box { min-width: 100%; }
        .footer-content { flex-direction: column; gap: 1rem; text-align: center; }
    }
</style>

<script is:inline>
document.addEventListener('DOMContentLoaded', () => {
  const input = document.getElementById('global-search');
  const dropdown = document.getElementById('search-dropdown');
  const indexEl = document.getElementById('search-index');
  if (!input || !dropdown || !indexEl) return;

  let items;
  try { items = JSON.parse(indexEl.textContent || '[]'); } catch { return; }
  let activeIdx = -1;

  function highlight(text, query) {
    if (!query) return text;
    const re = new RegExp('(' + query.replace(/[.*+?^${}()|[\]\\]/g, '\\$&') + ')', 'gi');
    return text.replace(re, '<mark>$1</mark>');
  }

  function render(results, query) {
    if (results.length === 0) {
      dropdown.innerHTML = '<div class="search-no-results">No districts found</div>';
      dropdown.classList.add('open');
      return;
    }
    dropdown.innerHTML = results.slice(0, 10).map((r, i) =>
      '<a class="search-result' + (i === activeIdx ? ' active' : '') + '" href="' + r.url + '">' +
        '<span class="search-result-name">' + highlight(r.name, query) + '</span>' +
        '<span class="search-result-state">' + (r.state ? highlight(r.state, query) : 'State') + '</span>' +
      '</a>'
    ).join('');
    dropdown.classList.add('open');
  }

  function search(query) {
    if (!query || query.length < 2) { dropdown.classList.remove('open'); activeIdx = -1; return; }
    const q = query.toLowerCase();
    // Prioritize startsWith, then includes
    const starts = items.filter(d => d.name.toLowerCase().startsWith(q));
    const includes = items.filter(d =>
      !d.name.toLowerCase().startsWith(q) &&
      (d.name.toLowerCase().includes(q) || d.state.toLowerCase().includes(q))
    );
    render([...starts, ...includes], query);
  }

  input.addEventListener('input', () => { activeIdx = -1; search(input.value.trim()); });

  input.addEventListener('keydown', (e) => {
    const results = dropdown.querySelectorAll('.search-result');
    if (!results.length) return;

    if (e.key === 'ArrowDown') {
      e.preventDefault();
      activeIdx = Math.min(activeIdx + 1, results.length - 1);
      results.forEach((r, i) => r.classList.toggle('active', i === activeIdx));
    } else if (e.key === 'ArrowUp') {
      e.preventDefault();
      activeIdx = Math.max(activeIdx - 1, 0);
      results.forEach((r, i) => r.classList.toggle('active', i === activeIdx));
    } else if (e.key === 'Enter') {
      e.preventDefault();
      if (activeIdx >= 0 && results[activeIdx]) {
        window.location.href = results[activeIdx].getAttribute('href');
      } else if (results.length > 0) {
        window.location.href = results[0].getAttribute('href');
      }
    } else if (e.key === 'Escape') {
      dropdown.classList.remove('open');
      activeIdx = -1;
    }
  });

  // Close dropdown on click outside
  document.addEventListener('click', (e) => {
    if (!e.target.closest('.search-wrapper')) {
      dropdown.classList.remove('open');
      activeIdx = -1;
    }
  });
});
</script>
